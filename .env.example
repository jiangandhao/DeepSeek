# DeepSeek 大模型
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MySQL
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=health
MYSQL_USER=health
MYSQL_PASSWORD=health123456

# Redis
REDIS_PASSWORD=

# 后端 JWT 密钥(生产环境务必替换为高强度随机值)
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-32-bytes
JWT_EXPIRE_MINUTES=1440

# 敏感字段加密密钥(独立于 JWT;生产务必替换为高强度随机值)
# 留空则回退使用 JWT_SECRET
CRYPTO_SECRET=change-this-to-another-long-random-secret-at-least-32-bytes

# 后端↔AI 服务内部共享密钥(生产务必替换;留空则 AI 服务不强制校验)
INTERNAL_API_KEY=change-this-internal-service-key

# 服务间地址(容器网络内使用服务名)
AI_SERVICE_URL=http://ai-service:8000

# 后端 CORS 允许来源(逗号分隔);默认 * 放开,生产务必收敛为具体前端域名
# 例:CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=*
