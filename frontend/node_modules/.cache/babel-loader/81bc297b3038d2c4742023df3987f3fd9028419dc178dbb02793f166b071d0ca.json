{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { useRouter } from 'vue-router';\nimport { ArrowDown } from '@element-plus/icons-vue';\nexport default {\n  name: 'App',\n  components: {\n    ArrowDown\n  },\n  setup() {\n    const router = useRouter();\n    const username = ref('用户');\n    const showHeader = computed(() => {\n      const noHeaderRoutes = ['/login', '/register'];\n      return !noHeaderRoutes.includes(router.currentRoute.value.path);\n    });\n    const activeMenu = computed(() => router.currentRoute.value.path);\n    const goToProfile = () => {\n      router.push('/profile');\n    };\n    const logout = () => {\n      localStorage.removeItem('token');\n      router.push('/login');\n    };\n    return {\n      username,\n      showHeader,\n      activeMenu,\n      goToProfile,\n      logout\n    };\n  }\n};","map":{"version":3,"names":["ref","computed","useRouter","ArrowDown","name","components","setup","router","username","showHeader","noHeaderRoutes","includes","currentRoute","value","path","activeMenu","goToProfile","push","logout","localStorage","removeItem"],"sources":["C:\\Users\\wangj\\Desktop\\deepseek-health-management\\frontend\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <el-container>\n      <el-header v-if=\"showHeader\">\n        <div class=\"header-content\">\n          <h1>DeepSeek 健康管理系统</h1>\n          <el-menu :default-active=\"activeMenu\" mode=\"horizontal\" router>\n            <el-menu-item index=\"/dashboard\">首页</el-menu-item>\n            <el-menu-item index=\"/blood-sugar\">血糖管理</el-menu-item>\n            <el-menu-item index=\"/health-manager\">AI健管师</el-menu-item>\n            <el-menu-item index=\"/checkup\">智能体检</el-menu-item>\n            <el-menu-item index=\"/risk-warning\">风险预警</el-menu-item>\n          </el-menu>\n          <div class=\"user-info\">\n            <el-dropdown>\n              <span class=\"el-dropdown-link\">\n                {{ username }} <el-icon><arrow-down /></el-icon>\n              </span>\n              <template #dropdown>\n                <el-dropdown-menu>\n                  <el-dropdown-item @click=\"goToProfile\">个人中心</el-dropdown-item>\n                  <el-dropdown-item divided @click=\"logout\">退出登录</el-dropdown-item>\n                </el-dropdown-menu>\n              </template>\n            </el-dropdown>\n          </div>\n        </div>\n      </el-header>\n      <el-main>\n        <router-view />\n      </el-main>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport { ref, computed } from 'vue'\nimport { useRouter } from 'vue-router'\nimport { ArrowDown } from '@element-plus/icons-vue'\n\nexport default {\n  name: 'App',\n  components: { ArrowDown },\n  setup() {\n    const router = useRouter()\n    const username = ref('用户')\n    const showHeader = computed(() => {\n      const noHeaderRoutes = ['/login', '/register']\n      return !noHeaderRoutes.includes(router.currentRoute.value.path)\n    })\n    const activeMenu = computed(() => router.currentRoute.value.path)\n\n    const goToProfile = () => {\n      router.push('/profile')\n    }\n\n    const logout = () => {\n      localStorage.removeItem('token')\n      router.push('/login')\n    }\n\n    return { username, showHeader, activeMenu, goToProfile, logout }\n  }\n}\n</script>\n\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;\n}\n\n#app {\n  min-height: 100vh;\n  background-color: #f5f7fa;\n}\n\n.el-header {\n  background-color: #fff;\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\n  padding: 0 20px;\n}\n\n.header-content {\n  display: flex;\n  align-items: center;\n  height: 100%;\n}\n\n.header-content h1 {\n  font-size: 20px;\n  color: #409eff;\n  margin-right: 50px;\n  white-space: nowrap;\n}\n\n.el-menu {\n  flex: 1;\n  border: none;\n}\n\n.user-info {\n  margin-left: auto;\n}\n\n.el-dropdown-link {\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  color: #606266;\n}\n\n.el-main {\n  padding: 20px;\n  min-height: calc(100vh - 60px);\n}\n</style>\n"],"mappings":"AAoCA,SAASA,GAAG,EAAEC,QAAO,QAAS,KAAI;AAClC,SAASC,SAAQ,QAAS,YAAW;AACrC,SAASC,SAAQ,QAAS,yBAAwB;AAElD,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IAAEF;EAAU,CAAC;EACzBG,KAAKA,CAAA,EAAG;IACN,MAAMC,MAAK,GAAIL,SAAS,CAAC;IACzB,MAAMM,QAAO,GAAIR,GAAG,CAAC,IAAI;IACzB,MAAMS,UAAS,GAAIR,QAAQ,CAAC,MAAM;MAChC,MAAMS,cAAa,GAAI,CAAC,QAAQ,EAAE,WAAW;MAC7C,OAAO,CAACA,cAAc,CAACC,QAAQ,CAACJ,MAAM,CAACK,YAAY,CAACC,KAAK,CAACC,IAAI;IAChE,CAAC;IACD,MAAMC,UAAS,GAAId,QAAQ,CAAC,MAAMM,MAAM,CAACK,YAAY,CAACC,KAAK,CAACC,IAAI;IAEhE,MAAME,WAAU,GAAIA,CAAA,KAAM;MACxBT,MAAM,CAACU,IAAI,CAAC,UAAU;IACxB;IAEA,MAAMC,MAAK,GAAIA,CAAA,KAAM;MACnBC,YAAY,CAACC,UAAU,CAAC,OAAO;MAC/Bb,MAAM,CAACU,IAAI,CAAC,QAAQ;IACtB;IAEA,OAAO;MAAET,QAAQ;MAAEC,UAAU;MAAEM,UAAU;MAAEC,WAAW;MAAEE;IAAO;EACjE;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}