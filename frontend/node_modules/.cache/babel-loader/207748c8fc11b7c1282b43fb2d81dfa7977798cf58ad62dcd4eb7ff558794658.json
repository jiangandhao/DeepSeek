{"ast":null,"code":"import { ref } from 'vue';\nimport { Promotion, InfoFilled } from '@element-plus/icons-vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'ExerciseRecommend',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const loading = ref(false);\n    const exercisePlan = ref(null);\n    const exerciseForm = ref({\n      age: 30,\n      level: 'intermediate',\n      duration: '60',\n      goal: 'general',\n      location: 'gym',\n      conditions: []\n    });\n    const stats = ref({\n      weeklyCount: 3,\n      weeklyCalories: 1200,\n      totalHours: 48,\n      streak: 7\n    });\n    const safetyTips = ref([{\n      text: '运动前进行5-10分钟热身',\n      color: '#409EFF'\n    }, {\n      text: '运动中注意补充水分',\n      color: '#67C23A'\n    }, {\n      text: '感到不适立即停止运动',\n      color: '#F56C6C'\n    }, {\n      text: '运动后进行拉伸放松',\n      color: '#E6A23C'\n    }]);\n    const getTypeColor = type => {\n      const map = {\n        '有氧': '',\n        '力量': 'success',\n        '柔韧': 'warning',\n        '休息': 'info'\n      };\n      return map[type] || '';\n    };\n    const generatePlan = async () => {\n      loading.value = true;\n      try {\n        await new Promise(resolve => setTimeout(resolve, 1500));\n        exercisePlan.value = {\n          weeklyPlan: [{\n            day: '周一',\n            type: '有氧',\n            duration: '45分钟',\n            calories: 350,\n            exercises: [{\n              name: '跑步机慢跑',\n              sets: 1,\n              reps: '30分钟',\n              rest: 0\n            }, {\n              name: '椭圆机',\n              sets: 1,\n              reps: '15分钟',\n              rest: 0\n            }]\n          }, {\n            day: '周二',\n            type: '力量',\n            duration: '60分钟',\n            calories: 280,\n            exercises: [{\n              name: '哑铃卧推',\n              sets: 4,\n              reps: '12次',\n              rest: 60\n            }, {\n              name: '杠铃划船',\n              sets: 4,\n              reps: '10次',\n              rest: 60\n            }, {\n              name: '肩推',\n              sets: 3,\n              reps: '12次',\n              rest: 60\n            }]\n          }, {\n            day: '周三',\n            type: '休息',\n            duration: '-',\n            calories: 0,\n            exercises: [{\n              name: '轻度拉伸',\n              sets: 1,\n              reps: '15分钟',\n              rest: 0\n            }]\n          }, {\n            day: '周四',\n            type: '力量',\n            duration: '60分钟',\n            calories: 300,\n            exercises: [{\n              name: '深蹲',\n              sets: 4,\n              reps: '10次',\n              rest: 90\n            }, {\n              name: '硬拉',\n              sets: 4,\n              reps: '8次',\n              rest: 90\n            }, {\n              name: '腿举',\n              sets: 3,\n              reps: '12次',\n              rest: 60\n            }]\n          }, {\n            day: '周五',\n            type: '有氧',\n            duration: '40分钟',\n            calories: 320,\n            exercises: [{\n              name: '动感单车',\n              sets: 1,\n              reps: '25分钟',\n              rest: 0\n            }, {\n              name: '跳绳',\n              sets: 3,\n              reps: '5分钟',\n              rest: 60\n            }]\n          }, {\n            day: '周六',\n            type: '柔韧',\n            duration: '50分钟',\n            calories: 150,\n            exercises: [{\n              name: '瑜伽基础',\n              sets: 1,\n              reps: '50分钟',\n              rest: 0\n            }]\n          }, {\n            day: '周日',\n            type: '休息',\n            duration: '-',\n            calories: 0,\n            exercises: [{\n              name: '户外散步',\n              sets: 1,\n              reps: '30分钟',\n              rest: 0\n            }]\n          }],\n          notes: '请根据自身感觉调整运动强度，如有不适请立即停止。建议运动前后各补充200ml水。'\n        };\n        ElMessage.success('运动方案生成成功');\n      } catch (error) {\n        ElMessage.error('生成失败: ' + error.message);\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      loading,\n      exercisePlan,\n      exerciseForm,\n      stats,\n      safetyTips,\n      getTypeColor,\n      generatePlan,\n      ref,\n      get Promotion() {\n        return Promotion;\n      },\n      get InfoFilled() {\n        return InfoFilled;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","Promotion","InfoFilled","ElMessage","loading","exercisePlan","exerciseForm","age","level","duration","goal","location","conditions","stats","weeklyCount","weeklyCalories","totalHours","streak","safetyTips","text","color","getTypeColor","type","map","generatePlan","value","Promise","resolve","setTimeout","weeklyPlan","day","calories","exercises","name","sets","reps","rest","notes","success","error","message"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/healthManager/ExerciseRecommend.vue"],"sourcesContent":["<template>\n  <div class=\"exercise-recommend\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\">\n        <el-card>\n          <template #header>\n            <div class=\"card-header\">\n              <span>个性化运动方案</span>\n              <el-button type=\"primary\" @click=\"generatePlan\" :loading=\"loading\">\n                <el-icon><Promotion /></el-icon>\n                生成运动方案\n              </el-button>\n            </div>\n          </template>\n\n          <el-form :model=\"exerciseForm\" label-width=\"100px\">\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"年龄\">\n                  <el-input-number v-model=\"exerciseForm.age\" :min=\"10\" :max=\"80\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"运动基础\">\n                  <el-select v-model=\"exerciseForm.level\">\n                    <el-option label=\"新手\" value=\"beginner\" />\n                    <el-option label=\"有一定基础\" value=\"intermediate\" />\n                    <el-option label=\"运动达人\" value=\"advanced\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"可用时间\">\n                  <el-select v-model=\"exerciseForm.duration\">\n                    <el-option label=\"30分钟\" value=\"30\" />\n                    <el-option label=\"45分钟\" value=\"45\" />\n                    <el-option label=\"60分钟\" value=\"60\" />\n                    <el-option label=\"90分钟\" value=\"90\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n            </el-row>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"运动目标\">\n                  <el-select v-model=\"exerciseForm.goal\">\n                    <el-option label=\"减脂\" value=\"fatLoss\" />\n                    <el-option label=\"增肌\" value=\"muscle\" />\n                    <el-option label=\"心肺功能\" value=\"cardio\" />\n                    <el-option label=\"柔韧性\" value=\"flexibility\" />\n                    <el-option label=\"综合健康\" value=\"general\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"运动场所\">\n                  <el-select v-model=\"exerciseForm.location\">\n                    <el-option label=\"健身房\" value=\"gym\" />\n                    <el-option label=\"家中\" value=\"home\" />\n                    <el-option label=\"户外\" value=\"outdoor\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"特殊状况\">\n                  <el-checkbox-group v-model=\"exerciseForm.conditions\">\n                    <el-checkbox label=\"knee\">膝盖不适</el-checkbox>\n                    <el-checkbox label=\"back\">腰背疼痛</el-checkbox>\n                    <el-checkbox label=\"heart\">心脏问题</el-checkbox>\n                  </el-checkbox-group>\n                </el-form-item>\n              </el-col>\n            </el-row>\n          </el-form>\n        </el-card>\n\n        <el-card v-if=\"exercisePlan\" style=\"margin-top: 20px;\">\n          <template #header>\n            <span>本周运动计划</span>\n          </template>\n\n          <el-table :data=\"exercisePlan.weeklyPlan\" border>\n            <el-table-column prop=\"day\" label=\"日期\" width=\"100\" />\n            <el-table-column prop=\"type\" label=\"运动类型\" width=\"120\">\n              <template #default=\"{ row }\">\n                <el-tag :type=\"getTypeColor(row.type)\">{{ row.type }}</el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column prop=\"exercises\" label=\"训练内容\">\n              <template #default=\"{ row }\">\n                <div v-for=\"ex in row.exercises\" :key=\"ex.name\" class=\"exercise-item\">\n                  <span class=\"exercise-name\">{{ ex.name }}</span>\n                  <span class=\"exercise-detail\">{{ ex.sets }}组 × {{ ex.reps }} | 休息{{ ex.rest }}秒</span>\n                </div>\n              </template>\n            </el-table-column>\n            <el-table-column prop=\"duration\" label=\"时长\" width=\"80\" />\n            <el-table-column prop=\"calories\" label=\"消耗(kcal)\" width=\"100\" />\n          </el-table>\n\n          <el-divider />\n\n          <el-alert :title=\"exercisePlan.notes\" type=\"info\" show-icon :closable=\"false\" />\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card>\n          <template #header>\n            <span>运动数据统计</span>\n          </template>\n          <el-descriptions :column=\"1\" border>\n            <el-descriptions-item label=\"本周运动次数\">{{ stats.weeklyCount }}次</el-descriptions-item>\n            <el-descriptions-item label=\"本周消耗\">{{ stats.weeklyCalories }}千卡</el-descriptions-item>\n            <el-descriptions-item label=\"累计运动\">{{ stats.totalHours }}小时</el-descriptions-item>\n            <el-descriptions-item label=\"连续打卡\">{{ stats.streak }}天</el-descriptions-item>\n          </el-descriptions>\n        </el-card>\n\n        <el-card style=\"margin-top: 20px;\">\n          <template #header>\n            <span>运动安全提示</span>\n          </template>\n          <div class=\"safety-tips\">\n            <div v-for=\"(tip, index) in safetyTips\" :key=\"index\" class=\"tip-item\">\n              <el-icon :style=\"{ color: tip.color }\"><InfoFilled /></el-icon>\n              <span>{{ tip.text }}</span>\n            </div>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { Promotion, InfoFilled } from '@element-plus/icons-vue'\nimport { ElMessage } from 'element-plus'\n\nconst loading = ref(false)\nconst exercisePlan = ref(null)\n\nconst exerciseForm = ref({\n  age: 30,\n  level: 'intermediate',\n  duration: '60',\n  goal: 'general',\n  location: 'gym',\n  conditions: []\n})\n\nconst stats = ref({\n  weeklyCount: 3,\n  weeklyCalories: 1200,\n  totalHours: 48,\n  streak: 7\n})\n\nconst safetyTips = ref([\n  { text: '运动前进行5-10分钟热身', color: '#409EFF' },\n  { text: '运动中注意补充水分', color: '#67C23A' },\n  { text: '感到不适立即停止运动', color: '#F56C6C' },\n  { text: '运动后进行拉伸放松', color: '#E6A23C' }\n])\n\nconst getTypeColor = (type) => {\n  const map = { '有氧': '', '力量': 'success', '柔韧': 'warning', '休息': 'info' }\n  return map[type] || ''\n}\n\nconst generatePlan = async () => {\n  loading.value = true\n  try {\n    await new Promise(resolve => setTimeout(resolve, 1500))\n\n    exercisePlan.value = {\n      weeklyPlan: [\n        {\n          day: '周一', type: '有氧', duration: '45分钟', calories: 350,\n          exercises: [\n            { name: '跑步机慢跑', sets: 1, reps: '30分钟', rest: 0 },\n            { name: '椭圆机', sets: 1, reps: '15分钟', rest: 0 }\n          ]\n        },\n        {\n          day: '周二', type: '力量', duration: '60分钟', calories: 280,\n          exercises: [\n            { name: '哑铃卧推', sets: 4, reps: '12次', rest: 60 },\n            { name: '杠铃划船', sets: 4, reps: '10次', rest: 60 },\n            { name: '肩推', sets: 3, reps: '12次', rest: 60 }\n          ]\n        },\n        {\n          day: '周三', type: '休息', duration: '-', calories: 0,\n          exercises: [{ name: '轻度拉伸', sets: 1, reps: '15分钟', rest: 0 }]\n        },\n        {\n          day: '周四', type: '力量', duration: '60分钟', calories: 300,\n          exercises: [\n            { name: '深蹲', sets: 4, reps: '10次', rest: 90 },\n            { name: '硬拉', sets: 4, reps: '8次', rest: 90 },\n            { name: '腿举', sets: 3, reps: '12次', rest: 60 }\n          ]\n        },\n        {\n          day: '周五', type: '有氧', duration: '40分钟', calories: 320,\n          exercises: [\n            { name: '动感单车', sets: 1, reps: '25分钟', rest: 0 },\n            { name: '跳绳', sets: 3, reps: '5分钟', rest: 60 }\n          ]\n        },\n        {\n          day: '周六', type: '柔韧', duration: '50分钟', calories: 150,\n          exercises: [\n            { name: '瑜伽基础', sets: 1, reps: '50分钟', rest: 0 }\n          ]\n        },\n        {\n          day: '周日', type: '休息', duration: '-', calories: 0,\n          exercises: [{ name: '户外散步', sets: 1, reps: '30分钟', rest: 0 }]\n        }\n      ],\n      notes: '请根据自身感觉调整运动强度，如有不适请立即停止。建议运动前后各补充200ml水。'\n    }\n\n    ElMessage.success('运动方案生成成功')\n  } catch (error) {\n    ElMessage.error('生成失败: ' + error.message)\n  } finally {\n    loading.value = false\n  }\n}\n</script>\n\n<style scoped>\n.exercise-recommend {\n  padding: 20px;\n}\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.exercise-item {\n  display: flex;\n  justify-content: space-between;\n  padding: 5px 0;\n}\n.exercise-name {\n  font-weight: bold;\n}\n.exercise-detail {\n  color: #999;\n}\n.safety-tips {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n.tip-item {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n</style>\n"],"mappings":"AAwIA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,SAAS,EAAEC,UAAU,QAAQ,yBAAwB;AAC9D,SAASC,SAAS,QAAQ,cAAa;;;;;;;IAEvC,MAAMC,OAAO,GAAGJ,GAAG,CAAC,KAAK;IACzB,MAAMK,YAAY,GAAGL,GAAG,CAAC,IAAI;IAE7B,MAAMM,YAAY,GAAGN,GAAG,CAAC;MACvBO,GAAG,EAAE,EAAE;MACPC,KAAK,EAAE,cAAc;MACrBC,QAAQ,EAAE,IAAI;MACdC,IAAI,EAAE,SAAS;MACfC,QAAQ,EAAE,KAAK;MACfC,UAAU,EAAE;IACd,CAAC;IAED,MAAMC,KAAK,GAAGb,GAAG,CAAC;MAChBc,WAAW,EAAE,CAAC;MACdC,cAAc,EAAE,IAAI;MACpBC,UAAU,EAAE,EAAE;MACdC,MAAM,EAAE;IACV,CAAC;IAED,MAAMC,UAAU,GAAGlB,GAAG,CAAC,CACrB;MAAEmB,IAAI,EAAE,eAAe;MAAEC,KAAK,EAAE;IAAU,CAAC,EAC3C;MAAED,IAAI,EAAE,WAAW;MAAEC,KAAK,EAAE;IAAU,CAAC,EACvC;MAAED,IAAI,EAAE,YAAY;MAAEC,KAAK,EAAE;IAAU,CAAC,EACxC;MAAED,IAAI,EAAE,WAAW;MAAEC,KAAK,EAAE;IAAU,EACvC;IAED,MAAMC,YAAY,GAAIC,IAAI,IAAK;MAC7B,MAAMC,GAAG,GAAG;QAAE,IAAI,EAAE,EAAE;QAAE,IAAI,EAAE,SAAS;QAAE,IAAI,EAAE,SAAS;QAAE,IAAI,EAAE;MAAO;MACvE,OAAOA,GAAG,CAACD,IAAI,CAAC,IAAI,EAAC;IACvB;IAEA,MAAME,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/BpB,OAAO,CAACqB,KAAK,GAAG,IAAG;MACnB,IAAI;QACF,MAAM,IAAIC,OAAO,CAACC,OAAO,IAAIC,UAAU,CAACD,OAAO,EAAE,IAAI,CAAC;QAEtDtB,YAAY,CAACoB,KAAK,GAAG;UACnBI,UAAU,EAAE,CACV;YACEC,GAAG,EAAE,IAAI;YAAER,IAAI,EAAE,IAAI;YAAEb,QAAQ,EAAE,MAAM;YAAEsB,QAAQ,EAAE,GAAG;YACtDC,SAAS,EAAE,CACT;cAAEC,IAAI,EAAE,OAAO;cAAEC,IAAI,EAAE,CAAC;cAAEC,IAAI,EAAE,MAAM;cAAEC,IAAI,EAAE;YAAE,CAAC,EACjD;cAAEH,IAAI,EAAE,KAAK;cAAEC,IAAI,EAAE,CAAC;cAAEC,IAAI,EAAE,MAAM;cAAEC,IAAI,EAAE;YAAE;UAElD,CAAC,EACD;YACEN,GAAG,EAAE,IAAI;YAAER,IAAI,EAAE,IAAI;YAAEb,QAAQ,EAAE,MAAM;YAAEsB,QAAQ,EAAE,G