{"ast":null,"code":"import { ref } from 'vue';\nimport { MagicStick, InfoFilled } from '@element-plus/icons-vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'DietPrescription',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const loading = ref(false);\n    const activeMeal = ref(['breakfast']);\n    const dietPlan = ref(null);\n    const nutritionChart = ref(null);\n    const dietForm = ref({\n      height: 170,\n      weight: 65,\n      targetWeight: 60,\n      goal: 'maintain',\n      preference: 'normal',\n      allergies: []\n    });\n    const dietTips = ref(['每日饮水量建议1500-2000ml', '细嚼慢咽，每餐20-30分钟', '避免暴饮暴食，定时定量', '减少油炸、烧烤类食物摄入', '多吃蔬菜水果，保证膳食纤维摄入']);\n    const generateDiet = async () => {\n      loading.value = true;\n      try {\n        await new Promise(resolve => setTimeout(resolve, 1500));\n        dietPlan.value = {\n          breakfast: [{\n            name: '全麦面包',\n            amount: '2片',\n            calories: 150,\n            category: '主食'\n          }, {\n            name: '水煮蛋',\n            amount: '1个',\n            calories: 80,\n            category: '蛋白质'\n          }, {\n            name: '低脂牛奶',\n            amount: '250ml',\n            calories: 120,\n            category: '乳制品'\n          }, {\n            name: '圣女果',\n            amount: '100g',\n            calories: 25,\n            category: '水果'\n          }],\n          breakfastCalories: 375,\n          lunch: [{\n            name: '糙米饭',\n            amount: '150g',\n            calories: 180,\n            category: '主食'\n          }, {\n            name: '清蒸鱼',\n            amount: '150g',\n            calories: 180,\n            category: '蛋白质'\n          }, {\n            name: '西兰花炒虾仁',\n            amount: '200g',\n            calories: 120,\n            category: '蔬菜'\n          }, {\n            name: '紫菜蛋花汤',\n            amount: '1碗',\n            calories: 50,\n            category: '汤品'\n          }],\n          lunchCalories: 530,\n          dinner: [{\n            name: '小米粥',\n            amount: '1碗',\n            calories: 100,\n            category: '主食'\n          }, {\n            name: '鸡胸肉沙拉',\n            amount: '200g',\n            calories: 200,\n            category: '蛋白质'\n          }, {\n            name: '凉拌黄瓜',\n            amount: '150g',\n            calories: 30,\n            category: '蔬菜'\n          }],\n          dinnerCalories: 330,\n          snacks: [{\n            name: '苹果',\n            time: '上午10:00',\n            calories: 80\n          }, {\n            name: '坚果(10颗)',\n            time: '下午15:00',\n            calories: 100\n          }],\n          totalCalories: 1385,\n          protein: 75,\n          carbs: 180,\n          fat: 45\n        };\n        ElMessage.success('饮食方案生成成功');\n      } catch (error) {\n        ElMessage.error('生成失败: ' + error.message);\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      loading,\n      activeMeal,\n      dietPlan,\n      nutritionChart,\n      dietForm,\n      dietTips,\n      generateDiet,\n      ref,\n      get MagicStick() {\n        return MagicStick;\n      },\n      get InfoFilled() {\n        return InfoFilled;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","MagicStick","InfoFilled","ElMessage","loading","activeMeal","dietPlan","nutritionChart","dietForm","height","weight","targetWeight","goal","preference","allergies","dietTips","generateDiet","value","Promise","resolve","setTimeout","breakfast","name","amount","calories","category","breakfastCalories","lunch","lunchCalories","dinner","dinnerCalories","snacks","time","totalCalories","protein","carbs","fat","success","error","message"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/healthManager/DietPrescription.vue"],"sourcesContent":["<template>\n  <div class=\"diet-prescription\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\">\n        <el-card>\n          <template #header>\n            <div class=\"card-header\">\n              <span>个性化饮食处方</span>\n              <el-button type=\"primary\" @click=\"generateDiet\" :loading=\"loading\">\n                <el-icon><MagicStick /></el-icon>\n                AI生成饮食方案\n              </el-button>\n            </div>\n          </template>\n\n          <el-form :model=\"dietForm\" label-width=\"100px\">\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"身高(cm)\">\n                  <el-input-number v-model=\"dietForm.height\" :min=\"100\" :max=\"250\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"体重(kg)\">\n                  <el-input-number v-model=\"dietForm.weight\" :min=\"30\" :max=\"200\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"目标体重\">\n                  <el-input-number v-model=\"dietForm.targetWeight\" :min=\"30\" :max=\"200\" />\n                </el-form-item>\n              </el-col>\n            </el-row>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"健康目标\">\n                  <el-select v-model=\"dietForm.goal\">\n                    <el-option label=\"减重\" value=\"lose\" />\n                    <el-option label=\"增重\" value=\"gain\" />\n                    <el-option label=\"维持\" value=\"maintain\" />\n                    <el-option label=\"控制血糖\" value=\"bloodSugar\" />\n                    <el-option label=\"控制血压\" value=\"bloodPressure\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"饮食偏好\">\n                  <el-select v-model=\"dietForm.preference\">\n                    <el-option label=\"普通饮食\" value=\"normal\" />\n                    <el-option label=\"素食\" value=\"vegetarian\" />\n                    <el-option label=\"低碳水\" value=\"lowCarb\" />\n                    <el-option label=\"地中海饮食\" value=\"mediterranean\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"过敏食物\">\n                  <el-select v-model=\"dietForm.allergies\" multiple>\n                    <el-option label=\"牛奶\" value=\"milk\" />\n                    <el-option label=\"鸡蛋\" value=\"egg\" />\n                    <el-option label=\"海鲜\" value=\"seafood\" />\n                    <el-option label=\"花生\" value=\"peanut\" />\n                    <el-option label=\"大豆\" value=\"soy\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n            </el-row>\n          </el-form>\n        </el-card>\n\n        <el-card v-if=\"dietPlan\" style=\"margin-top: 20px;\">\n          <template #header>\n            <span>今日饮食方案</span>\n          </template>\n\n          <el-collapse v-model=\"activeMeal\">\n            <el-collapse-item title=\"🌅 早餐 (建议 7:00-8:00)\" name=\"breakfast\">\n              <div class=\"meal-content\">\n                <div v-for=\"item in dietPlan.breakfast\" :key=\"item.name\" class=\"food-item\">\n                  <div class=\"food-info\">\n                    <h4>{{ item.name }}</h4>\n                    <p>{{ item.amount }} | {{ item.calories }}千卡</p>\n                  </div>\n                  <el-tag size=\"small\">{{ item.category }}</el-tag>\n                </div>\n                <div class=\"meal-total\">\n                  <span>早餐总热量: {{ dietPlan.breakfastCalories }}千卡</span>\n                </div>\n              </div>\n            </el-collapse-item>\n\n            <el-collapse-item title=\"☀️ 午餐 (建议 12:00-13:00)\" name=\"lunch\">\n              <div class=\"meal-content\">\n                <div v-for=\"item in dietPlan.lunch\" :key=\"item.name\" class=\"food-item\">\n                  <div class=\"food-info\">\n                    <h4>{{ item.name }}</h4>\n                    <p>{{ item.amount }} | {{ item.calories }}千卡</p>\n                  </div>\n                  <el-tag size=\"small\">{{ item.category }}</el-tag>\n                </div>\n                <div class=\"meal-total\">\n                  <span>午餐总热量: {{ dietPlan.lunchCalories }}千卡</span>\n                </div>\n              </div>\n            </el-collapse-item>\n\n            <el-collapse-item title=\"🌙 晚餐 (建议 18:00-19:00)\" name=\"dinner\">\n              <div class=\"meal-content\">\n                <div v-for=\"item in dietPlan.dinner\" :key=\"item.name\" class=\"food-item\">\n                  <div class=\"food-info\">\n                    <h4>{{ item.name }}</h4>\n                    <p>{{ item.amount }} | {{ item.calories }}千卡</p>\n                  </div>\n                  <el-tag size=\"small\">{{ item.category }}</el-tag>\n                </div>\n                <div class=\"meal-total\">\n                  <span>晚餐总热量: {{ dietPlan.dinnerCalories }}千卡</span>\n                </div>\n              </div>\n            </el-collapse-item>\n\n            <el-collapse-item title=\"🍎 加餐建议\" name=\"snack\">\n              <div class=\"meal-content\">\n                <div v-for=\"item in dietPlan.snacks\" :key=\"item.name\" class=\"food-item\">\n                  <div class=\"food-info\">\n                    <h4>{{ item.name }}</h4>\n                    <p>{{ item.time }} | {{ item.calories }}千卡</p>\n                  </div>\n                </div>\n              </div>\n            </el-collapse-item>\n          </el-collapse>\n\n          <el-divider />\n\n          <el-row :gutter=\"20\">\n            <el-col :span=\"6\">\n              <el-statistic title=\"每日总热量\" :value=\"dietPlan.totalCalories\" suffix=\"千卡\" />\n            </el-col>\n            <el-col :span=\"6\">\n              <el-statistic title=\"蛋白质\" :value=\"dietPlan.protein\" suffix=\"g\" />\n            </el-col>\n            <el-col :span=\"6\">\n              <el-statistic title=\"碳水化合物\" :value=\"dietPlan.carbs\" suffix=\"g\" />\n            </el-col>\n            <el-col :span=\"6\">\n              <el-statistic title=\"脂肪\" :value=\"dietPlan.fat\" suffix=\"g\" />\n            </el-col>\n          </el-row>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card>\n          <template #header>\n            <span>营养摄入分析</span>\n          </template>\n          <div ref=\"nutritionChart\" style=\"height: 300px;\"></div>\n        </el-card>\n\n        <el-card style=\"margin-top: 20px;\">\n          <template #header>\n            <span>饮食注意事项</span>\n          </template>\n          <ul class=\"tips-list\">\n            <li v-for=\"(tip, index) in dietTips\" :key=\"index\">\n              <el-icon><InfoFilled /></el-icon>\n              {{ tip }}\n            </li>\n          </ul>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { MagicStick, InfoFilled } from '@element-plus/icons-vue'\nimport { ElMessage } from 'element-plus'\n\nconst loading = ref(false)\nconst activeMeal = ref(['breakfast'])\nconst dietPlan = ref(null)\nconst nutritionChart = ref(null)\n\nconst dietForm = ref({\n  height: 170,\n  weight: 65,\n  targetWeight: 60,\n  goal: 'maintain',\n  preference: 'normal',\n  allergies: []\n})\n\nconst dietTips = ref([\n  '每日饮水量建议1500-2000ml',\n  '细嚼慢咽，每餐20-30分钟',\n  '避免暴饮暴食，定时定量',\n  '减少油炸、烧烤类食物摄入',\n  '多吃蔬菜水果，保证膳食纤维摄入'\n])\n\nconst generateDiet = async () => {\n  loading.value = true\n  try {\n    await new Promise(resolve => setTimeout(resolve, 1500))\n\n    dietPlan.value = {\n      breakfast: [\n        { name: '全麦面包', amount: '2片', calories: 150, category: '主食' },\n        { name: '水煮蛋', amount: '1个', calories: 80, category: '蛋白质' },\n        { name: '低脂牛奶', amount: '250ml', calories: 120, category: '乳制品' },\n        { name: '圣女果', amount: '100g', calories: 25, category: '水果' }\n      ],\n      breakfastCalories: 375,\n      lunch: [\n        { name: '糙米饭', amount: '150g', calories: 180, category: '主食' },\n        { name: '清蒸鱼', amount: '150g', calories: 180, category: '蛋白质' },\n        { name: '西兰花炒虾仁', amount: '200g', calories: 120, category: '蔬菜' },\n        { name: '紫菜蛋花汤', amount: '1碗', calories: 50, category: '汤品' }\n      ],\n      lunchCalories: 530,\n      dinner: [\n        { name: '小米粥', amount: '1碗', calories: 100, category: '主食' },\n        { name: '鸡胸肉沙拉', amount: '200g', calories: 200, category: '蛋白质' },\n        { name: '凉拌黄瓜', amount: '150g', calories: 30, category: '蔬菜' }\n      ],\n      dinnerCalories: 330,\n      snacks: [\n        { name: '苹果', time: '上午10:00', calories: 80 },\n        { name: '坚果(10颗)', time: '下午15:00', calories: 100 }\n      ],\n      totalCalories: 1385,\n      protein: 75,\n      carbs: 180,\n      fat: 45\n    }\n\n    ElMessage.success('饮食方案生成成功')\n  } catch (error) {\n    ElMessage.error('生成失败: ' + error.message)\n  } finally {\n    loading.value = false\n  }\n}\n</script>\n\n<style scoped>\n.diet-prescription {\n  padding: 20px;\n}\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.meal-content {\n  padding: 10px;\n}\n.food-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 10px 0;\n  border-bottom: 1px dashed #eee;\n}\n.food-info h4 {\n  margin: 0 0 5px 0;\n}\n.food-info p {\n  margin: 0;\n  color: #999;\n  font-size: 12px;\n}\n.meal-total {\n  text-align: right;\n  padding: 10px 0;\n  font-weight: bold;\n  color: #409EFF;\n}\n.tips-list {\n  list-style: none;\n  padding: 0;\n}\n.tips-list li {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 8px 0;\n  border-bottom: 1px solid #f0f0f0;\n}\n</style>\n"],"mappings":"AAiLA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,UAAU,EAAEC,UAAU,QAAQ,yBAAwB;AAC/D,SAASC,SAAS,QAAQ,cAAa;;;;;;;IAEvC,MAAMC,OAAO,GAAGJ,GAAG,CAAC,KAAK;IACzB,MAAMK,UAAU,GAAGL,GAAG,CAAC,CAAC,WAAW,CAAC;IACpC,MAAMM,QAAQ,GAAGN,GAAG,CAAC,IAAI;IACzB,MAAMO,cAAc,GAAGP,GAAG,CAAC,IAAI;IAE/B,MAAMQ,QAAQ,GAAGR,GAAG,CAAC;MACnBS,MAAM,EAAE,GAAG;MACXC,MAAM,EAAE,EAAE;MACVC,YAAY,EAAE,EAAE;MAChBC,IAAI,EAAE,UAAU;MAChBC,UAAU,EAAE,QAAQ;MACpBC,SAAS,EAAE;IACb,CAAC;IAED,MAAMC,QAAQ,GAAGf,GAAG,CAAC,CACnB,oBAAoB,EACpB,gBAAgB,EAChB,aAAa,EACb,cAAc,EACd,iBAAgB,CACjB;IAED,MAAMgB,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/BZ,OAAO,CAACa,KAAK,GAAG,IAAG;MACnB,IAAI;QACF,MAAM,IAAIC,OAAO,CAACC,OAAO,IAAIC,UAAU,CAACD,OAAO,EAAE,IAAI,CAAC;QAEtDb,QAAQ,CAACW,KAAK,GAAG;UACfI,SAAS,EAAE,CACT;YAAEC,IAAI,EAAE,MAAM;YAAEC,MAAM,EAAE,IAAI;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAK,CAAC,EAC7D;YAAEH,IAAI,EAAE,KAAK;YAAEC,MAAM,EAAE,IAAI;YAAEC,QAAQ,EAAE,EAAE;YAAEC,QAAQ,EAAE;UAAM,CAAC,EAC5D;YAAEH,IAAI,EAAE,MAAM;YAAEC,MAAM,EAAE,OAAO;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAM,CAAC,EACjE;YAAEH,IAAI,EAAE,KAAK;YAAEC,MAAM,EAAE,MAAM;YAAEC,QAAQ,EAAE,EAAE;YAAEC,QAAQ,EAAE;UAAK,EAC7D;UACDC,iBAAiB,EAAE,GAAG;UACtBC,KAAK,EAAE,CACL;YAAEL,IAAI,EAAE,KAAK;YAAEC,MAAM,EAAE,MAAM;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAK,CAAC,EAC9D;YAAEH,IAAI,EAAE,KAAK;YAAEC,MAAM,EAAE,MAAM;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAM,CAAC,EAC/D;YAAEH,IAAI,EAAE,QAAQ;YAAEC,MAAM,EAAE,MAAM;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAK,CAAC,EACjE;YAAEH,IAAI,EAAE,OAAO;YAAEC,MAAM,EAAE,IAAI;YAAEC,QAAQ,EAAE,EAAE;YAAEC,QAAQ,EAAE;UAAK,EAC7D;UACDG,aAAa,EAAE,GAAG;UAClBC,MAAM,EAAE,CACN;YAAEP,IAAI,EAAE,KAAK;YAAEC,MAAM,EAAE,IAAI;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAK,CAAC,EAC5D;YAAEH,IAAI,EAAE,OAAO;YAAEC,MAAM,EAAE,MAAM;YAAEC,QAAQ,EAAE,GAAG;YAAEC,QAAQ,EAAE;UAAM,CAAC,EACjE;YAAEH,IAAI,EAAE,MAAM;YAAEC,MAAM,EAAE,MAAM;YAAEC,QAAQ,EAAE,EAAE;YAAEC,QAAQ,EAAE;UAAK,EAC9D