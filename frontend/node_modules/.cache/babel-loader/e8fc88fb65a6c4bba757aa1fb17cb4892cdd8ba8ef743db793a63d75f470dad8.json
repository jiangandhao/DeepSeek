{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport * as echarts from 'echarts';\nexport default {\n  __name: 'TrendAnalysis',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const chartRef = ref(null);\n    const dateRange = ref([]);\n    const trendData = ref([{\n      date: '2024-01-10',\n      fasting: 5.2,\n      postprandial: 7.1,\n      status: '正常'\n    }, {\n      date: '2024-01-11',\n      fasting: 5.5,\n      postprandial: 7.8,\n      status: '正常'\n    }, {\n      date: '2024-01-12',\n      fasting: 5.8,\n      postprandial: 8.2,\n      status: '偏高'\n    }, {\n      date: '2024-01-13',\n      fasting: 5.4,\n      postprandial: 7.5,\n      status: '正常'\n    }, {\n      date: '2024-01-14',\n      fasting: 5.6,\n      postprandial: 7.9,\n      status: '正常'\n    }, {\n      date: '2024-01-15',\n      fasting: 5.3,\n      postprandial: 7.2,\n      status: '正常'\n    }]);\n    onMounted(() => {\n      if (chartRef.value) {\n        const chart = echarts.init(chartRef.value);\n        const option = {\n          title: {\n            text: '血糖趋势图'\n          },\n          tooltip: {\n            trigger: 'axis'\n          },\n          legend: {\n            data: ['空腹血糖', '餐后血糖']\n          },\n          xAxis: {\n            type: 'category',\n            data: trendData.value.map(item => item.date)\n          },\n          yAxis: {\n            type: 'value',\n            name: 'mmol/L'\n          },\n          series: [{\n            name: '空腹血糖',\n            type: 'line',\n            data: trendData.value.map(item => item.fasting),\n            smooth: true\n          }, {\n            name: '餐后血糖',\n            type: 'line',\n            data: trendData.value.map(item => item.postprandial),\n            smooth: true\n          }]\n        };\n        chart.setOption(option);\n      }\n    });\n    const __returned__ = {\n      chartRef,\n      dateRange,\n      trendData,\n      ref,\n      onMounted,\n      get echarts() {\n        return echarts;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","echarts","chartRef","dateRange","trendData","date","fasting","postprandial","status","value","chart","init","option","title","text","tooltip","trigger","legend","data","xAxis","type","map","item","yAxis","name","series","smooth","setOption"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/bloodSugar/TrendAnalysis.vue"],"sourcesContent":["<template>\n  <div class=\"trend-analysis-container\">\n    <el-card>\n      <template #header>\n        <div class=\"card-header\">\n          <span>血糖趋势分析</span>\n          <el-date-picker\n            v-model=\"dateRange\"\n            type=\"daterange\"\n            range-separator=\"至\"\n            start-placeholder=\"开始日期\"\n            end-placeholder=\"结束日期\"\n          ></el-date-picker>\n        </div>\n      </template>\n      <div ref=\"chartRef\" style=\"width: 100%; height: 400px;\"></div>\n      <el-table :data=\"trendData\" style=\"width: 100%; margin-top: 20px;\">\n        <el-table-column prop=\"date\" label=\"日期\" width=\"180\"></el-table-column>\n        <el-table-column prop=\"fasting\" label=\"空腹血糖(mmol/L)\" width=\"160\"></el-table-column>\n        <el-table-column prop=\"postprandial\" label=\"餐后血糖(mmol/L)\" width=\"160\"></el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\n          <template #default=\"{ row }\">\n            <el-tag :type=\"row.status === '正常' ? 'success' : 'warning'\">{{ row.status }}</el-tag>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport * as echarts from 'echarts'\n\nconst chartRef = ref(null)\nconst dateRange = ref([])\nconst trendData = ref([\n  {