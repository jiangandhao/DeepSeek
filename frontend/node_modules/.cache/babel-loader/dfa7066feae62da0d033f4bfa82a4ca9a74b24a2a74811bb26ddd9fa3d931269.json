{"ast":null,"code":"import { ref, computed, onMounted, nextTick } from 'vue';\nimport * as echarts from 'echarts';\nexport default {\n  __name: 'Dashboard',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const username = ref('用户');\n    const activeTab = ref('blood-sugar');\n    const chartRef = ref(null);\n    const score = ref(86);\n    const greeting = computed(() => {\n      const hour = new Date().getHours();\n      if (hour < 6) return '夜深了';\n      if (hour < 9) return '早上好';\n      if (hour < 12) return '上午好';\n      if (hour < 14) return '中午好';\n      if (hour < 17) return '下午好';\n      if (hour < 22) return '晚上好';\n      return '夜深了';\n    });\n    const stats = [{\n      label: '今日血糖',\n      value: '5.6',\n      trend: '正常',\n      trendType: 'normal',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/></svg>',\n      iconBg: 'rgba(26, 107, 90, 0.1)',\n      sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,18 10,14 20,16 30,10 40,12 50,8 60,10 70,6 80,4\" fill=\"none\" stroke=\"#1a6b5a\" stroke-width=\"2\"/></svg>'\n    }, {\n      label: '本周运动',\n      value: '4.5h',\n      trend: '+12%',\n      trendType: 'up',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg>',\n      iconBg: 'rgba(196, 149, 106, 0.1)',\n      sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,20 10,16 20,18 30,12 40,14 50,10 60,8 70,6 80,4\" fill=\"none\" stroke=\"#c4956a\" stroke-width=\"2\"/></svg>'\n    }, {\n      label: '睡眠质量',\n      value: '85分',\n      trend: '+5%',\n      trendType: 'up',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"/></svg>',\n      iconBg: 'rgba(90, 143, 191, 0.1)',\n      sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,14 10,16 20,12 30,14 40,10 50,12 60,8 70,10 80,6\" fill=\"none\" stroke=\"#5a8fbf\" stroke-width=\"2\"/></svg>'\n    }, {\n      label: '风险预警',\n      value: '2',\n      trend: '待处理',\n      trendType: 'warning',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\"/><line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"13\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/></svg>',\n      iconBg: 'rgba(199, 84, 80, 0.1)',\n      sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,12 10,14 20,10 30,16 40,12 50,14 60,10 70,12 80,8\" fill=\"none\" stroke=\"#c75450\" stroke-width=\"2\"/></svg>'\n    }];\n    const chartTabs = [{\n      key: 'blood-sugar',\n      label: '血糖'\n    }, {\n      key: 'blood-pressure',\n      label: '血压'\n    }, {\n      key: 'weight',\n      label: '体重'\n    }];\n    const quickActions = [{\n      path: '/blood-sugar',\n      label: '记录血糖',\n      desc: '记录今日血糖数据',\n      bg: 'rgba(26, 107, 90, 0.08)',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#1a6b5a\" stroke-width=\"1.5\"><path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/></svg>'\n    }, {\n      path: '/checkup',\n      label: '预约体检',\n      desc: '智能体检预约',\n      bg: 'rgba(196, 149, 106, 0.08)',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#c4956a\" stroke-width=\"1.5\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>'\n    }, {\n      path: '/health-manager',\n      label: 'AI 咨询',\n      desc: '获取健康建议',\n      bg: 'rgba(90, 143, 191, 0.08)',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#5a8fbf\" stroke-width=\"1.5\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg>'\n    }, {\n      path: '/risk-warning',\n      label: '风险评估',\n      desc: '查看风险报告',\n      bg: 'rgba(199, 84, 80, 0.08)',\n      icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#c75450\" stroke-width=\"1.5\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>'\n    }];\n    const recentActivities = [{\n      title: '完成血糖检测',\n      desc: '空腹血糖 5.6 mmol/L，处于正常范围',\n      time: '10:30',\n      color: '#1a6b5a'\n    }, {\n      title: '体检报告已生成',\n      desc: '年度综合体检报告已可查看',\n      time: '昨天',\n      color: '#c4956a'\n    }, {\n      title: '风险评估完成',\n      desc: '心血管风险等级：低风险',\n      time: '2天前',\n      color: '#5a8fbf'\n    }, {\n      title: '饮食计划更新',\n      desc: 'AI 已根据您的血糖数据调整饮食建议',\n      time: '3天前',\n      color: '#4a9d7e'\n    }];\n    const scoreDetails = [{\n      label: '血糖控制',\n      value: '92分',\n      percent: 92,\n      color: '#1a6b5a'\n    }, {\n      label: '运动达标',\n      value: '78分',\n      percent: 78,\n      color: '#c4956a'\n    }, {\n      label: '饮食规律',\n      value: '85分',\n      percent: 85,\n      color: '#5a8fbf'\n    }, {\n      label: '睡眠质量',\n      value: '88分',\n      percent: 88,\n      color: '#4a9d7e'\n    }];\n    onMounted(() => {\n      nextTick(() => {\n        if (chartRef.value) {\n          initChart();\n        }\n      });\n    });\n    const initChart = () => {\n      const chart = echarts.init(chartRef.value);\n      const days = ['周一', '周二', '周三', '周四', '周五', '周六', '周日'];\n      const option = {\n        tooltip: {\n          trigger: 'axis',\n          backgroundColor: 'rgba(255, 255, 255, 0.95)',\n          borderColor: 'rgba(0, 0, 0, 0.06)',\n          borderWidth: 1,\n          textStyle: {\n            color: '#2c2c2c',\n            fontFamily: 'DM Sans'\n          },\n          axisPointer: {\n            type: 'cross',\n            crossStyle: {\n              color: '#9a9a9a'\n            }\n          }\n        },\n        legend: {\n          data: ['空腹血糖', '餐后血糖'],\n          right: 0,\n          top: 0,\n          textStyle: {\n            fontFamily: 'DM Sans',\n            fontSize: 12,\n            color: '#6b6b6b'\n          },\n          itemWidth: 16,\n          itemHeight: 2\n        },\n        grid: {\n          left: 0,\n          right: 0,\n          bottom: 0,\n          top: 40,\n          containLabel: true\n        },\n        xAxis: {\n          type: 'category',\n          data: days,\n          axisLine: {\n            show: false\n          },\n          axisTick: {\n            show: false\n          },\n          axisLabel: {\n            color: '#9a9a9a',\n            fontFamily: 'DM Sans',\n            fontSize: 11\n          }\n        },\n        yAxis: {\n          type: 'value',\n          name: 'mmol/L',\n          nameTextStyle: {\n            color: '#9a9a9a',\n            fontFamily: 'DM Sans',\n            fontSize: 11\n          },\n          axisLine: {\n            show: false\n          },\n          axisTick: {\n            show: false\n          },\n          splitLine: {\n            lineStyle: {\n              color: 'rgba(0, 0, 0, 0.04)',\n              type: 'dashed'\n            }\n          },\n          axisLabel: {\n            color: '#9a9a9a',\n            fontFamily: 'DM Sans',\n            fontSize: 11\n          }\n        },\n        series: [{\n          name: '空腹血糖',\n          type: 'line',\n          data: [5.8, 6.1, 5.9, 6.2, 5.7, 6.0, 5.9],\n          smooth: true,\n          symbol: 'circle',\n          symbolSize: 6,\n          lineStyle: {\n            color: '#1a6b5a',\n            width: 2.5\n          },\n          itemStyle: {\n            color: '#1a6b5a',\n            borderWidth: 2,\n            borderColor: '#fff'\n          },\n          areaStyle: {\n            color: {\n              type: 'linear',\n              x: 0,\n              y: 0,\n              x2: 0,\n              y2: 1,\n              colorStops: [{\n                offset: 0,\n                color: 'rgba(26, 107, 90, 0.15)'\n              }, {\n                offset: 1,\n                color: 'rgba(26, 107, 90, 0)'\n              }]\n            }\n          }\n        }, {\n          name: '餐后血糖',\n          type: 'line',\n          data: [7.2, 7.8, 7.5, 8.1, 7.3, 7.6, 7.4],\n          smooth: true,\n          symbol: 'circle',\n          symbolSize: 6,\n          lineStyle: {\n            color: '#c4956a',\n            width: 2.5\n          },\n          itemStyle: {\n            color: '#c4956a',\n            borderWidth: 2,\n            borderColor: '#fff'\n          },\n          areaStyle: {\n            color: {\n              type: 'linear',\n              x: 0,\n              y: 0,\n              x2: 0,\n              y2: 1,\n              colorStops: [{\n                offset: 0,\n                color: 'rgba(196, 149, 106, 0.15)'\n              }, {\n                offset: 1,\n                color: 'rgba(196, 149, 106, 0)'\n              }]\n            }\n          }\n        }]\n      };\n      chart.setOption(option);\n      window.addEventListener('resize', () => chart.resize());\n    };\n    const __returned__ = {\n      username,\n      activeTab,\n      chartRef,\n      score,\n      greeting,\n      stats,\n      chartTabs,\n      quickActions,\n      recentActivities,\n      scoreDetails,\n      initChart,\n      ref,\n      computed,\n      onMounted,\n      nextTick,\n      get echarts() {\n        return echarts;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","nextTick","echarts","username","activeTab","chartRef","score","greeting","hour","Date","getHours","stats","label","value","trend","trendType","icon","iconBg","sparkline","chartTabs","key","quickActions","path","desc","bg","recentActivities","title","time","color","scoreDetails","percent","initChart","chart","init","days","option","tooltip","trigger","backgroundColor","borderColor","borderWidth","textStyle","fontFamily","axisPointer","type","crossStyle","legend","data","right","top","fontSize","itemWidth","itemHeight","grid","left","bottom","containLabel","xAxis","axisLine","show","axisTick","axisLabel","yAxis","name","nameTextStyle","splitLine","lineStyle","series","smooth","symbol","symbolSize","width","itemStyle","areaStyle","x","y","x2","y2","colorStops","offset","setOption","window","addEventListener","resize"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard\">\n    <!-- 欢迎区域 -->\n    <section class=\"welcome-section\">\n      <div class=\"welcome-content\">\n        <div class=\"welcome-text\">\n          <p class=\"welcome-greeting\">{{ greeting }}，{{ username }}</p>\n          <h1 class=\"welcome-title\">健康概览</h1>\n          <p class=\"welcome-desc\">您的整体健康状况良好，今日有 <strong>2</strong> 项待办事项</p>\n        </div>\n        <div class=\"welcome-art\">\n          <div class=\"art-circle art-circle-1\"></div>\n          <div class=\"art-circle art-circle-2\"></div>\n          <div class=\"art-circle art-circle-3\"></div>\n          <div class=\"art-pulse\"></div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 统计卡片 -->\n    <section class=\"stats-section\">\n      <div class=\"stat-card\" v-for=\"(stat, index) in stats\" :key=\"index\" :style=\"{ animationDelay: `${index * 0.1}s` }\">\n        <div class=\"stat-icon-wrap\" :style=\"{ background: stat.iconBg }\">\n          <div class=\"stat-icon\" v-html=\"stat.icon\"></div>\n        </div>\n        <div class=\"stat-info\">\n          <span class=\"stat-label\">{{ stat.label }}</span>\n          <span class=\"stat-value\">{{ stat.value }}</span>\n          <span class=\"stat-trend\" :class=\"stat.trendType\">\n            <svg v-if=\"stat.trendType === 'up'\" viewBox=\"0 0 12 12\" width=\"12\" height=\"12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M2 8l4-4 4 4\" />\n            </svg>\n            <svg v-else viewBox=\"0 0 12 12\" width=\"12\" height=\"12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M2 4l4 4 4-4\" />\n            </svg>\n            {{ stat.trend }}\n          </span>\n        </div>\n        <div class=\"stat-sparkline\" v-html=\"stat.sparkline\"></div>\n      </div>\n    </section>\n\n    <!-- 主要内容区域 -->\n    <section class=\"main-grid\">\n      <!-- 左侧：健康趋势 -->\n      <div class=\"grid-card chart-card\">\n        <div class=\"card-header\">\n          <div class=\"card-title-group\">\n            <h3 class=\"card-title\">健康趋势</h3>\n            <span class=\"card-subtitle\">近7天数据</span>\n          </div>\n          <div class=\"card-tabs\">\n            <button\n              v-for=\"tab in chartTabs\"\n              :key=\"tab.key\"\n              class=\"tab-btn\"\n              :class=\"{ active: activeTab === tab.key }\"\n              @click=\"activeTab = tab.key\"\n            >\n              {{ tab.label }}\n            </button>\n          </div>\n        </div>\n        <div class=\"chart-container\">\n          <div ref=\"chartRef\" class=\"chart-canvas\"></div>\n        </div>\n      </div>\n\n      <!-- 右侧：快速操作 -->\n      <div class=\"grid-card actions-card\">\n        <div class=\"card-header\">\n          <h3 class=\"card-title\">快速操作</h3>\n        </div>\n        <div class=\"actions-grid\">\n          <router-link v-for=\"action in quickActions\" :key=\"action.path\" :to=\"action.path\" class=\"action-item\">\n            <div class=\"action-icon\" :style=\"{ background: action.bg }\">\n              <div v-html=\"action.icon\"></div>\n            </div>\n            <span class=\"action-label\">{{ action.label }}</span>\n            <span class=\"action-desc\">{{ action.desc }}</span>\n          </router-link>\n        </div>\n      </div>\n\n      <!-- 左下：最近活动 -->\n      <div class=\"grid-card activity-card\">\n        <div class=\"card-header\">\n          <h3 class=\"card-title\">最近活动</h3>\n          <a href=\"#\" class=\"view-all\">查看全部</a>\n        </div>\n        <div class=\"activity-list\">\n          <div v-for=\"(activity, index) in recentActivities\" :key=\"index\" class=\"activity-item\">\n            <div class=\"activity-dot\" :style=\"{ background: activity.color }\"></div>\n            <div class=\"activity-line\" v-if=\"index < recentActivities.length - 1\"></div>\n            <div class=\"activity-content\">\n              <div class=\"activity-header\">\n                <span class=\"activity-title\">{{ activity.title }}</span>\n                <span class=\"activity-time\">{{ activity.time }}</span>\n              </div>\n              <p class=\"activity-desc\">{{ activity.desc }}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- 右下：健康评分 -->\n      <div class=\"grid-card score-card\">\n        <div class=\"card-header\">\n          <h3 class=\"card-title\">健康评分</h3>\n          <span class=\"card-badge\">本月</span>\n        </div>\n        <div class=\"score-content\">\n          <div class=\"score-ring-container\">\n            <svg viewBox=\"0 0 120 120\" class=\"score-ring\">\n              <circle cx=\"60\" cy=\"60\" r=\"52\" fill=\"none\" stroke=\"rgba(26,107,90,0.1)\" stroke-width=\"8\" />\n              <circle\n                cx=\"60\" cy=\"60\" r=\"52\"\n                fill=\"none\"\n                stroke=\"url(#scoreGradient)\"\n                stroke-width=\"8\"\n                stroke-linecap=\"round\"\n                :stroke-dasharray=\"326.73\"\n                :stroke-dashoffset=\"326.73 * (1 - score / 100)\"\n                transform=\"rotate(-90 60 60)\"\n                class=\"score-progress\"\n              />\n              <defs>\n                <linearGradient id=\"scoreGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                  <stop offset=\"0%\" stop-color=\"#1a6b5a\" />\n                  <stop offset=\"100%\" stop-color=\"#4a9d7e\" />\n                </linearGradient>\n              </defs>\n            </svg>\n            <div class=\"score-value\">\n              <span class=\"score-number\">{{ score }}</span>\n              <span class=\"score-unit\">分</span>\n            </div>\n          </div>\n          <div class=\"score-details\">\n            <div class=\"score-item\" v-for=\"item in scoreDetails\" :key=\"item.label\">\n              <div class=\"score-item-header\">\n                <span class=\"score-item-label\">{{ item.label }}</span>\n                <span class=\"score-item-value\">{{ item.value }}</span>\n              </div>\n              <div class=\"score-bar\">\n                <div class=\"score-bar-fill\" :style=\"{ width: item.percent + '%', background: item.color }\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- AI 建议 -->\n    <section class=\"ai-section\">\n      <div class=\"ai-card\">\n        <div class=\"ai-icon\">\n          <svg viewBox=\"0 0 24 24\" width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">\n            <path d=\"M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z\" />\n            <path d=\"M12 6v6l4 2\" />\n          </svg>\n        </div>\n        <div class=\"ai-content\">\n          <h4 class=\"ai-title\">AI 健康建议</h4>\n          <p class=\"ai-text\">根据您近7天的血糖数据，建议您适当减少晚餐碳水摄入量，并在餐后30分钟进行15分钟散步，有助于改善餐后血糖峰值。</p>\n        </div>\n        <button class=\"ai-action\">查看详情</button>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, nextTick } from 'vue'\nimport * as echarts from 'echarts'\n\nconst username = ref('用户')\nconst activeTab = ref('blood-sugar')\nconst chartRef = ref(null)\nconst score = ref(86)\n\nconst greeting = computed(() => {\n  const hour = new Date().getHours()\n  if (hour < 6) return '夜深了'\n  if (hour < 9) return '早上好'\n  if (hour < 12) return '上午好'\n  if (hour < 14) return '中午好'\n  if (hour < 17) return '下午好'\n  if (hour < 22) return '晚上好'\n  return '夜深了'\n})\n\nconst stats = [\n  {\n    label: '今日血糖',\n    value: '5.6',\n    trend: '正常',\n    trendType: 'normal',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/></svg>',\n    iconBg: 'rgba(26, 107, 90, 0.1)',\n    sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,18 10,14 20,16 30,10 40,12 50,8 60,10 70,6 80,4\" fill=\"none\" stroke=\"#1a6b5a\" stroke-width=\"2\"/></svg>'\n  },\n  {\n    label: '本周运动',\n    value: '4.5h',\n    trend: '+12%',\n    trendType: 'up',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg>',\n    iconBg: 'rgba(196, 149, 106, 0.1)',\n    sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,20 10,16 20,18 30,12 40,14 50,10 60,8 70,6 80,4\" fill=\"none\" stroke=\"#c4956a\" stroke-width=\"2\"/></svg>'\n  },\n  {\n    label: '睡眠质量',\n    value: '85分',\n    trend: '+5%',\n    trendType: 'up',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"/></svg>',\n    iconBg: 'rgba(90, 143, 191, 0.1)',\n    sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,14 10,16 20,12 30,14 40,10 50,12 60,8 70,10 80,6\" fill=\"none\" stroke=\"#5a8fbf\" stroke-width=\"2\"/></svg>'\n  },\n  {\n    label: '风险预警',\n    value: '2',\n    trend: '待处理',\n    trendType: 'warning',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\"/><line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"13\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/></svg>',\n    iconBg: 'rgba(199, 84, 80, 0.1)',\n    sparkline: '<svg viewBox=\"0 0 80 24\" width=\"80\" height=\"24\"><polyline points=\"0,12 10,14 20,10 30,16 40,12 50,14 60,10 70,12 80,8\" fill=\"none\" stroke=\"#c75450\" stroke-width=\"2\"/></svg>'\n  }\n]\n\nconst chartTabs = [\n  { key: 'blood-sugar', label: '血糖' },\n  { key: 'blood-pressure', label: '血压' },\n  { key: 'weight', label: '体重' }\n]\n\nconst quickActions = [\n  {\n    path: '/blood-sugar',\n    label: '记录血糖',\n    desc: '记录今日血糖数据',\n    bg: 'rgba(26, 107, 90, 0.08)',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#1a6b5a\" stroke-width=\"1.5\"><path d=\"M22 12h-4l-3 9L9 3l-3 9H2\"/></svg>'\n  },\n  {\n    path: '/checkup',\n    label: '预约体检',\n    desc: '智能体检预约',\n    bg: 'rgba(196, 149, 106, 0.08)',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#c4956a\" stroke-width=\"1.5\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>'\n  },\n  {\n    path: '/health-manager',\n    label: 'AI 咨询',\n    desc: '获取健康建议',\n    bg: 'rgba(90, 143, 191, 0.08)',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#5a8fbf\" stroke-width=\"1.5\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg>'\n  },\n  {\n    path: '/risk-warning',\n    label: '风险评估',\n    desc: '查看风险报告',\n    bg: 'rgba(199, 84, 80, 0.08)',\n    icon: '<svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"#c75450\" stroke-width=\"1.5\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>'\n  }\n]\n\nconst recentActivities = [\n  { title: '完成血糖检测', desc: '空腹血糖 5.6 mmol/L，处于正常范围', time: '10:30', color: '#1a6b5a' },\n  { title: '体检报告已生成', desc: '年度综合体检报告已可查看', time: '昨天', color: '#c4956a' },\n  { title: '风险评估完成', desc: '心血管风险等级：低风险', time: '2天前', color: '#5a8fbf' },\n  { title: '饮食计划更新', desc: 'AI 已根据您的血糖数据调整饮食建议', time: '3天前', color: '#4a9d7e' }\n]\n\nconst scoreDetails = [\n  { label: '血糖控制', value: '92分', percent: 92, color: '#1a6b5a' },\n  { label: '运动达标', value: '78分', percent: 78, color: '#c4956a' },\n  { label: '饮食规律', value: '85分', percent: 85, color: '#5a8fbf' },\n  { label: '睡眠质量', value: '88分', percent: 88, color: '#4a9d7e' }\n]\n\nonMounted(() => {\n  nextTick(() => {\n    if (chartRef.value) {\n      initChart()\n    }\n  })\n})\n\nconst initChart = () => {\n  const chart = echarts.init(chartRef.value)\n  const days = ['周一', '周二', '周三', '周四', '周五', '周六', '周日']\n\n  const option = {\n    tooltip: {\n      trigger: 'axis',\n      backgroundColor: 'rgba(255, 255, 255, 0.95)',\n      borderColor: 'rgba(0, 0, 0, 0.06)',\n      borderWidth: 1,\n      textStyle: {\n        color: '#2c2c2c',\n        fontFamily: 'DM Sans'\n      },\n      axisPointer: {\n        type: 'cross',\n        crossStyle: {\n          color: '#9a9a9a'\n        }\n      }\n    },\n    legend: {\n      data: ['空腹血糖', '餐后血糖'],\n      right: 0,\n      top: 0,\n      textStyle: {\n        fontFamily: 'DM Sans',\n        fontSize: 12,\n        color: '#6b6b6b'\n      },\n      itemWidth: 16,\n      itemHeight: 2\n    },\n    grid: {\n      left: 0,\n      right: 0,\n      bottom: 0,\n      top: 40,\n      containLabel: true\n    },\n    xAxis: {\n      type: 'category',\n      data