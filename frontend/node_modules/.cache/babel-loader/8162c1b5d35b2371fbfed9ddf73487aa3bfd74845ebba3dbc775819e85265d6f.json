{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { Warning } from '@element-plus/icons-vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'RiskAssessment',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const loading = ref(false);\n    const result = ref(null);\n    const assessmentForm = ref({\n      age: 30,\n      gender: 'male',\n      smoking: 'never',\n      drinking: 'never',\n      exercise: 'medium',\n      sleep: 'good',\n      familyHistory: [],\n      height: 170,\n      weight: 65,\n      systolicBP: 120,\n      diastolicBP: 80,\n      bloodSugar: 5.6,\n      cholesterol: 4.5,\n      triglyceride: 1.5,\n      uricAcid: 350\n    });\n    const bmi = computed(() => {\n      const h = assessmentForm.value.height / 100;\n      return (assessmentForm.value.weight / (h * h)).toFixed(1);\n    });\n    const getRiskType = level => {\n      const map = {\n        '低风险': 'success',\n        '中风险': 'warning',\n        '高风险': 'danger'\n      };\n      return map[level] || 'info';\n    };\n    const getRiskColor = level => {\n      const map = {\n        '低风险': '#67C23A',\n        '中风险': '#E6A23C',\n        '高风险': '#F56C6C'\n      };\n      return map[level] || '#909399';\n    };\n    const startAssessment = async () => {\n      loading.value = true;\n      try {\n        // 模拟AI评估 - 实际调用后端API\n        await new Promise(resolve => setTimeout(resolve, 1500));\n        const bmiVal = parseFloat(bmi.value);\n        let totalScore = 0;\n        const risks = [];\n\n        // BMI风险\n        if (bmiVal > 28) totalScore += 20;else if (bmiVal > 24) totalScore += 10;\n\n        // 血压风险\n        if (assessmentForm.value.systolicBP > 140) totalScore += 15;\n        if (assessmentForm.value.diastolicBP > 90) totalScore += 10;\n\n        // 血糖风险\n        if (assessmentForm.value.bloodSugar > 7.0) totalScore += 20;else if (assessmentForm.value.bloodSugar > 6.1) totalScore += 10;\n\n        // 家族史风险\n        totalScore += assessmentForm.value.familyHistory.length * 5;\n\n        // 生成疾病风险\n        risks.push({\n          disease: '心血管疾病',\n          level: totalScore > 30 ? '高风险' : totalScore > 15 ? '中风险' : '低风险',\n          probability: Math.min(95, totalScore * 2 + 10)\n        });\n        risks.push({\n          disease: '糖尿病',\n          level: assessmentForm.value.bloodSugar > 6.1 ? '高风险' : '低风险',\n          probability: assessmentForm.value.bloodSugar > 6.1 ? 75 : 20\n        });\n        risks.push({\n          disease: '高血压',\n          level: assessmentForm.value.systolicBP > 140 ? '高风险' : '低风险',\n          probability: assessmentForm.value.systolicBP > 140 ? 80 : 15\n        });\n        const suggestions = [];\n        if (bmiVal > 24) suggestions.push('建议控制饮食，适当增加运动量，将BMI控制在正常范围');\n        if (assessmentForm.value.systolicBP > 130) suggestions.push('注意低盐饮食，定期监测血压');\n        if (assessmentForm.value.bloodSugar > 6.1) suggestions.push('减少糖分摄入，定期检查血糖');\n        if (assessmentForm.value.smoking !== 'never') suggestions.push('建议戒烟，减少心血管疾病风险');\n        suggestions.push('保持规律作息，每年定期体检');\n        result.value = {\n          score: totalScore,\n          level: totalScore > 30 ? 'high' : totalScore > 15 ? 'medium' : 'low',\n          levelText: totalScore > 30 ? '高风险' : totalScore > 15 ? '中风险' : '低风险',\n          risks,\n          suggestions\n        };\n        ElMessage.success('评估完成');\n      } catch (error) {\n        ElMessage.error('评估失败: ' + error.message);\n      } finally {\n        loading.value = false;\n      }\n    };\n    const __returned__ = {\n      loading,\n      result,\n      assessmentForm,\n      bmi,\n      getRiskType,\n      getRiskColor,\n      startAssessment,\n      ref,\n      computed,\n      get Warning() {\n        return Warning;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","Warning","ElMessage","loading","result","assessmentForm","age","gender","smoking","drinking","exercise","sleep","familyHistory","height","weight","systolicBP","diastolicBP","bloodSugar","cholesterol","triglyceride","uricAcid","bmi","h","value","toFixed","getRiskType","level","map","getRiskColor","startAssessment","Promise","resolve","setTimeout","bmiVal","parseFloat","totalScore","risks","length","push","disease","probability","Math","min","suggestions","score","levelText","success","error","message"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/healthManager/RiskAssessment.vue"],"sourcesContent":["<template>\n  <div class=\"risk-assessment\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\">\n        <el-card class=\"assessment-form\">\n          <template #header>\n            <div class=\"card-header\">\n              <span>健康风险评估</span>\n              <el-button type=\"primary\" @click=\"startAssessment\" :loading=\"loading\">\n                开始评估\n              </el-button>\n            </div>\n          </template>\n\n          <el-form :model=\"assessmentForm\" label-width=\"120px\" ref=\"formRef\">\n            <el-divider content-position=\"left\">基本信息</el-divider>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"12\">\n                <el-form-item label=\"年龄\" prop=\"age\">\n                  <el-input-number v-model=\"assessmentForm.age\" :min=\"1\" :max=\"120\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"12\">\n                <el-form-item label=\"性别\" prop=\"gender\">\n                  <el-radio-group v-model=\"assessmentForm.gender\">\n                    <el-radio label=\"male\">男</el-radio>\n                    <el-radio label=\"female\">女</el-radio>\n                  </el-radio-group>\n                </el-form-item>\n              </el-col>\n            </el-row>\n\n            <el-divider content-position=\"left\">生活习惯</el-divider>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"12\">\n                <el-form-item label=\"吸烟\" prop=\"smoking\">\n                  <el-select v-model=\"assessmentForm.smoking\">\n                    <el-option label=\"从不\" value=\"never\" />\n                    <el-option label=\"偶尔\" value=\"occasional\" />\n                    <el-option label=\"经常\" value=\"regular\" />\n                    <el-option label=\"已戒烟\" value=\"quit\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"12\">\n                <el-form-item label=\"饮酒\" prop=\"drinking\">\n                  <el-select v-model=\"assessmentForm.drinking\">\n                    <el-option label=\"从不\" value=\"never\" />\n                    <el-option label=\"偶尔\" value=\"occasional\" />\n                    <el-option label=\"经常\" value=\"regular\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n            </el-row>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"12\">\n                <el-form-item label=\"运动频率\" prop=\"exercise\">\n                  <el-select v-model=\"assessmentForm.exercise\">\n                    <el-option label=\"几乎不运动\" value=\"none\" />\n                    <el-option label=\"每周1-2次\" value=\"low\" />\n                    <el-option label=\"每周3-5次\" value=\"medium\" />\n                    <el-option label=\"每天运动\" value=\"high\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"12\">\n                <el-form-item label=\"睡眠质量\" prop=\"sleep\">\n                  <el-select v-model=\"assessmentForm.sleep\">\n                    <el-option label=\"很差\" value=\"poor\" />\n                    <el-option label=\"一般\" value=\"fair\" />\n                    <el-option label=\"良好\" value=\"good\" />\n                    <el-option label=\"很好\" value=\"excellent\" />\n                  </el-select>\n                </el-form-item>\n              </el-col>\n            </el-row>\n\n            <el-divider content-position=\"left\">家族病史</el-divider>\n            <el-form-item label=\"家族病史\" prop=\"familyHistory\">\n              <el-checkbox-group v-model=\"assessmentForm.familyHistory\">\n                <el-checkbox label=\"hypertension\">高血压</el-checkbox>\n                <el-checkbox label=\"diabetes\">糖尿病</el-checkbox>\n                <el-checkbox label=\"heartDisease\">心脏病</el-checkbox>\n                <el-checkbox label=\"cancer\">癌症</el-checkbox>\n                <el-checkbox label=\"stroke\">中风</el-checkbox>\n                <el-checkbox label=\"none\">无</el-checkbox>\n              </el-checkbox-group>\n            </el-form-item>\n\n            <el-divider content-position=\"left\">体检指标</el-divider>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"身高(cm)\">\n                  <el-input-number v-model=\"assessmentForm.height\" :min=\"100\" :max=\"250\" :step=\"0.1\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"体重(kg)\">\n                  <el-input-number v-model=\"assessmentForm.weight\" :min=\"30\" :max=\"200\" :step=\"0.1\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"BMI\">\n                  <el-input :value=\"bmi\" disabled />\n                </el-form-item>\n              </el-col>\n            </el-row>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"收缩压(mmHg)\">\n                  <el-input-number v-model=\"assessmentForm.systolicBP\" :min=\"60\" :max=\"250\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"舒张压(mmHg)\">\n                  <el-input-number v-model=\"assessmentForm.diastolicBP\" :min=\"40\" :max=\"150\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"血糖(mmol/L)\">\n                  <el-input-number v-model=\"assessmentForm.bloodSugar\" :min=\"2\" :max=\"30\" :step=\"0.1\" />\n                </el-form-item>\n              </el-col>\n            </el-row>\n            <el-row :gutter=\"20\">\n              <el-col :span=\"8\">\n                <el-form-item label=\"总胆固醇\">\n                  <el-input-number v-model=\"assessmentForm.cholesterol\" :min=\"2\" :max=\"15\" :step=\"0.1\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"甘油三酯\">\n                  <el-input-number v-model=\"assessmentForm.triglyceride\" :min=\"0.5\" :max=\"10\" :step=\"0.1\" />\n                </el-form-item>\n              </el-col>\n              <el-col :span=\"8\">\n                <el-form-item label=\"尿酸(μmol/L)\">\n                  <el-input-number v-model=\"assessmentForm.uricAcid\" :min=\"100\" :max=\"800\" />\n                </el-form-item>\n              </el-col>\n            </el-row>\n          </el-form>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card class=\"result-card\">\n          <template #header>\n            <span>评估结果</span>\n          </template>\n\n          <div v-if=\"result\" class=\"result-content\">\n            <div class=\"risk-level\" :class=\"result.level\">\n              <el-icon :size=\"48\"><Warning /></el-icon>\n              <h2>{{ result.levelText }}</h2>\n              <p>综合风险评分: {{ result.score }}分</p>\n            </div>\n\n            <el-divider />\n\n            <h4>疾病风险分析</h4>\n            <div v-for=\"item in result.risks\" :key=\"item.disease\" class=\"risk-item\">\n              <div class=\"risk-label\">\n                <span>{{ item.disease }}</span>\n                <el-tag :type=\"getRiskType(item.level)\" size=\"small\">{{ item.level }}</el-tag>\n              </div>\n              <el-progress :percentage=\"item.probability\" :color=\"getRiskColor(item.level)\" />\n            </div>\n\n            <el-divider />\n\n            <h4>预防建议</h4>\n            <ul class=\"suggestions\">\n              <li v-for=\"(suggestion, index) in result.suggestions\" :key=\"index\">\n                {{ suggestion }}\n              </li>\n            </ul>\n          </div>\n\n          <el-empty v-else description=\"请填写信息后开始评估\" />\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { Warning } from '@element-plus/icons-vue'\nimport { ElMessage } from 'element-plus'\n\nconst loading = ref(false)\nconst result = ref(null)\n\nconst assessmentForm = ref({\n  age: 30,\n  gender: 'male',\n  smoking: 'never',\n  drinking: 'never',\n  exercise: 'medium',\n  sleep: 'good',\n  familyHistory: [],\n  height: 170,\n  weight: 65,\n  systolicBP: 120,\n  diastolicBP: 80,\n  bloodSugar: 5.6,\n  cholesterol: 4.5,\n  triglyceride: 1.5,\n  uricAcid: 350\n})\n\nconst bmi = computed(() => {\n  const h = assessmentForm.value.height / 100\n  return (assessmentForm.value.weight / (h * h)).toFixed(1)\n})\n\nconst getRiskType = (level) => {\n  const map = { '低风险': 'success', '中风险': 'warning', '高风险': 'danger' }\n  return map[level] || 'info'\n}\n\nconst getRiskColor = (level) => {\n  const map = { '低风险': '#67C23A', '中风险': '#E6A23C', '高风险': '#F56C6C' }\n  return map[level] || '#909399'\n}\n\nconst startAssessment = async () => {\n  loading.value = true\n  try {\n    // 模拟AI评估 - 实际调用后端API\n    await new Promise(resolve => setTimeout(resolve, 1500))\n\n    const bmiVal = parseFloat(bmi.value)\n    let totalScore = 0\n    const risks = []\n\n    // BMI风险\n    if (bmiVal > 28) totalScore += 20\n    else if (bmiVal > 24) totalScore += 10\n\n    // 血压风险\n    if (assessmentForm.value.systolicBP > 140) totalScore += 15\n    if (assessmentForm.value.diastolicBP > 90) totalScore += 10\n\n    // 血糖风险\n    if (assessmentForm.value.bloodSugar > 7.0) totalScore += 20\n    else if (assessmentForm.value.bloodSugar > 6.1) totalScore += 10\n\n    // 家族史风险\n    totalScore += assessmentForm.value.familyHistory.length * 5\n\n    // 生成疾病风险\n    risks.push({\n      disease: '心血管疾病',\n      level: totalScore > 30 ? '高风险' : totalScore > 15 ? '中风险' : '低风险',\n      probability: Math.min(95, totalScore * 2 + 10)\n    })\n    risks.push({\n      disease: '糖尿病',\n      level: assessmentForm.value.bloodSugar > 6.1 ? '高风险' : '低风险',\n      probability: assessmentForm.value.bloodSugar > 6.1 ? 75 : 20\n    })\n    risks.push({\n      disease: '高血压',\n      level: assessmentForm.value.systolicBP > 140 ? '高风险' : '低风险',\n      probability: assessmentForm.value.systolicBP > 140 ? 80 : 15\n    })\n\n    const suggestions = []\n    if (bmiVal > 24) suggestions.push('建议控制饮食，适当增加运动量，将BMI控制在正常范围')\n    if (assessmentForm.value.systolicBP > 130) suggestions.push('注意低盐饮食，定期监测血压')\n    if (assessmentForm.value.bloodSugar > 6.1) suggestions.push('减少糖分摄入，定期检查血糖')\n    if (assessmentForm.value.smoking !== 'never') suggestions.push('建议戒烟，减少心血管疾病风险')\n    suggestions.push('保持规律作息，每年定期体检')\n\n    result.value = {\n      score: totalScore,\n      level: totalScore > 30 ? 'high' : totalScore > 15 ? 'medium' : 'low',\n      levelText: totalScore > 30 ? '高风险' : totalScore > 15 ? '中风险' : '低风险',\n      risks,\n      suggestions\n    }\n\n    ElMessage.success('评估完成')\n  } catch (error) {\n    ElMessage.error('评估失败: ' + error.message)\n  } finally {\n    loading.value = false\n  }\n}\n</script>\n\n<style scoped>\n.risk-assessment {\n  padding: 20px;\n}\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.risk-level {\n  text-align: center;\n  padding: 20px;\n  border-radius: 8px;\n}\n.risk-level.low { background: #f0f9eb; color: #67C23A; }\n.risk-level.medium { background: #fdf6ec; color: #E6A23C; }\n.risk-level.high { background: #fef0f0; color: #F56C6C; }\n.risk-item {\n  margin-bottom: 15px;\n}\n.risk-label {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: 5px;\n}\n.suggestions {\n  padding-left: 20px;\n}\n.suggestions li {\n  margin-bottom: 8px;\n  line-height: 1.6;\n}\n</style>\n"],"mappings":"AA2LA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,OAAO,QAAQ,yBAAwB;AAChD,SAASC,SAAS,QAAQ,cAAa;;;;;;;IAEvC,MAAMC,OAAO,GAAGJ,GAAG,CAAC,KAAK;IACzB,MAAMK,MAAM,GAAGL,GAAG,CAAC,IAAI;IAEvB,MAAMM,cAAc,GAAGN,GAAG,CAAC;MACzBO,GAAG,EAAE,EAAE;MACPC,MAAM,EAAE,MAAM;MACdC,OAAO,EAAE,OAAO;MAChBC,QAAQ,EAAE,OAAO;MACjBC,QAAQ,EAAE,QAAQ;MAClBC,KAAK,EAAE,MAAM;MACbC,aAAa,EAAE,EAAE;MACjBC,MAAM,EAAE,GAAG;MACXC,MAAM,EAAE,EAAE;MACVC,UAAU,EAAE,GAAG;MACfC,WAAW,EAAE,EAAE;MACfC,UAAU,EAAE,GAAG;MACfC,WAAW,EAAE,GAAG;MAChBC,YAAY,EAAE,GAAG;MACjBC,QAAQ,EAAE;IACZ,CAAC;IAED,MAAMC,GAAG,GAAGrB,QAAQ,CAAC,MAAM;MACzB,MAAMsB,CAAC,GAAGjB,cAAc,CAACkB,KAAK,CAACV,MAAM,GAAG,GAAE;MAC1C,OAAO,CAACR,cAAc,CAACkB,KAAK,CAACT,MAAM,IAAIQ,CAAC,GAAGA,CAAC,CAAC,EAAEE,OAAO,CAAC,CAAC;IAC1D,CAAC;IAED,MAAMC,WAAW,GAAIC,KAAK,IAAK;MAC7B,MAAMC,GAAG,GAAG;QAAE,KAAK,EAAE,SAAS;QAAE,KAAK,EAAE,SAAS;QAAE,KAAK,EAAE;MAAS;MAClE,OAAOA,GAAG,CAACD,KAAK,CAAC,IAAI,MAAK;IAC5B;IAEA,MAAME,YAAY,GAAIF,KAAK,IAAK;MAC9B,MAAMC,GAAG,GAAG;QAAE,KAAK,EAAE,SAAS;QAAE,KAAK,EAAE,SAAS;QAAE,KAAK,EAAE;MAAU;MACnE,OAAOA,GAAG,CAACD,KAAK,CAAC,IAAI,SAAQ;IAC/B;IAEA,MAAMG,eAAe,GAAG,MAAAA,CAAA,KAAY;MAClC1B,OAAO,CAACoB,KAAK,GAAG,IAAG;MACnB,IAAI;QACF;QACA,MAAM,IAAIO,OAAO,CAACC,OAAO,IAAIC,UAAU,CAACD,OAAO,EAAE,IAAI,CAAC;QAEtD,MAAME,MAAM,GAAGC,UAAU,CAACb,GAAG,CAACE,KAAK;QACnC,IAAIY,UAAU,GAAG;QACjB,MAAMC,KAAK,GAAG,EAAC;;QAEf;QACA,IAAIH,MAAM,GAAG,EAAE,EAAEE,UAAU,IAAI,EAAC,MAC3B,IAAIF,MAAM,GAAG,EAAE,EAAEE,UAAU,IAAI,EAAC;;QAErC;QACA,IAAI9B,cAAc,CAACkB,KAAK,CAACR,UAAU,GAAG,GAAG,EAAEoB,UAAU,IAAI,EA