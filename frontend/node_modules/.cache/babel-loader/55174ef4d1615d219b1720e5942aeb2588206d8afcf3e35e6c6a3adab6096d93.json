{"ast":null,"code":"import { ref, computed } from 'vue';\nimport { Setting, Bell, CircleCloseFilled, WarningFilled, Warning, InfoFilled } from '@element-plus/icons-vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'EarlyWarning',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const activeTab = ref('all');\n    const warnings = ref([{\n      id: 1,\n      level: '高风险',\n      title: '血糖严重超标预警',\n      content: '您今日空腹血糖测量值为8.2mmol/L，已超过警戒线。建议立即调整饮食并咨询医生。',\n      action: '建议：1）立即就医；2）严格控制碳水摄入；3）增加运动量',\n      time: '2025-01-10 09:30',\n      read: false\n    }, {\n      id: 2,\n      level: '中风险',\n      title: '血压波动预警',\n      content: '近3天血压测量值波动较大（120-158/80-95），建议规律作息并监测血压。',\n      time: '2025-01-10 08:15',\n      read: false\n    }, {\n      id: 3,\n      level: '低风险',\n      title: '体重增加提醒',\n      content: '近一个月体重增加2kg，已接近超重上限，建议控制饮食。',\n      time: '2025-01-09 20:00',\n      read: true\n    }, {\n      id: 4,\n      level: '中风险',\n      title: '血脂异常提醒',\n      content: '上次体检血脂指标偏高，已超过3个月未复查，建议近期安排复查。',\n      time: '2025-01-08 10:00',\n      read: true\n    }]);\n    const reminders = ref([{\n      id: 1,\n      type: 'medication',\n      title: '用药提醒',\n      content: '二甲双胍 500mg - 晚餐后服用',\n      time: '18:00'\n    }, {\n      id: 2,\n      type: 'exercise',\n      title: '运动提醒',\n      content: '今日还未运动，建议进行30分钟散步',\n      time: '19:00'\n    }, {\n      id: 3,\n      type: 'checkup',\n      title: '复查提醒',\n      content: '心血管科复查还有15天',\n      time: '全天'\n    }, {\n      id: 4,\n      type: 'measurement',\n      title: '测量提醒',\n      content: '请测量今日睡前血压',\n      time: '21:00'\n    }]);\n    const thresholds = ref({\n      bloodSugarHigh: 7.0,\n      bloodPressureHigh: 140,\n      heartRateHigh: 100,\n      bmiHigh: 24\n    });\n    const warningStats = ref({\n      today: 2,\n      week: 8,\n      unread: 2,\n      resolved: 15\n    });\n    const highWarnings = computed(() => warnings.value.filter(w => w.level === '高风险'));\n    const getLevelType = level => {\n      const map = {\n        '高风险': 'danger',\n        '中风险': 'warning',\n        '低风险': 'info'\n      };\n      return map[level] || 'info';\n    };\n    const getWarningIcon = level => {\n      const map = {\n        '高风险': 'CircleCloseFilled',\n        '中风险': 'WarningFilled',\n        '低风险': 'InfoFilled'\n      };\n      return map[level] || 'InfoFilled';\n    };\n    const markAllRead = () => {\n      warnings.value.forEach(w => w.read = true);\n      ElMessage.success('已全部标记为已读');\n    };\n    const handleWarning = warning => {\n      warning.read = true;\n      ElMessage.info(`处理预警: ${warning.title}`);\n    };\n    const dismissWarning = warning => {\n      warning.read = true;\n      ElMessage.success('已忽略');\n    };\n    const showSettings = () => {\n      ElMessage.info('打开预警设置');\n    };\n    const saveThresholds = () => {\n      ElMessage.success('预警阈值保存成功');\n    };\n    const __returned__ = {\n      activeTab,\n      warnings,\n      reminders,\n      thresholds,\n      warningStats,\n      highWarnings,\n      getLevelType,\n      getWarningIcon,\n      markAllRead,\n      handleWarning,\n      dismissWarning,\n      showSettings,\n      saveThresholds,\n      ref,\n      computed,\n      get Setting() {\n        return Setting;\n      },\n      get Bell() {\n        return Bell;\n      },\n      get CircleCloseFilled() {\n        return CircleCloseFilled;\n      },\n      get WarningFilled() {\n        return WarningFilled;\n      },\n      get Warning() {\n        return Warning;\n      },\n      get InfoFilled() {\n        return InfoFilled;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","Setting","Bell","CircleCloseFilled","WarningFilled","Warning","InfoFilled","ElMessage","activeTab","warnings","id","level","title","content","action","time","read","reminders","type","thresholds","bloodSugarHigh","bloodPressureHigh","heartRateHigh","bmiHigh","warningStats","today","week","unread","resolved","highWarnings","value","filter","w","getLevelType","map","getWarningIcon","markAllRead","forEach","success","handleWarning","warning","info","dismissWarning","showSettings","saveThresholds"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/riskWarning/EarlyWarning.vue"],"sourcesContent":["<template>\n  <div class=\"early-warning\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\">\n        <el-card>\n          <template #header>\n            <div class=\"card-header\">\n              <span>预警通知</span>\n              <div>\n                <el-button @click=\"markAllRead\">全部已读</el-button>\n                <el-button type=\"primary\" @click=\"showSettings\">\n                  <el-icon><Setting /></el-icon>\n                  预警设置\n                </el-button>\n              </div>\n            </div>\n          </template>\n\n          <el-tabs v-model=\"activeTab\">\n            <el-tab-pane label=\"全部预警\" name=\"all\">\n              <div v-for=\"warning in warnings\" :key=\"warning.id\" class=\"warning-item\" :class=\"[warning.level, { unread: !warning.read }]\">\n                <div class=\"warning-icon\">\n                  <el-icon :size=\"24\"><component :is=\"getWarningIcon(warning.level)\" /></el-icon>\n                </div>\n                <div class=\"warning-content\">\n                  <div class=\"warning-header\">\n                    <el-tag :type=\"getLevelType(warning.level)\" size=\"small\">{{ warning.level }}</el-tag>\n                    <span class=\"warning-time\">{{ warning.time }}</span>\n                  </div>\n                  <h4>{{ warning.title }}</h4>\n                  <p>{{ warning.content }}</p>\n                  <div class=\"warning-actions\">\n                    <el-button type=\"primary\" link @click=\"handleWarning(warning)\">查看详情</el-button>\n                    <el-button type=\"info\" link @click=\"dismissWarning(warning)\">忽略</el-button>\n                  </div>\n                </div>\n              </div>\n            </el-tab-pane>\n\n            <el-tab-pane label=\"高风险预警\" name=\"high\">\n              <div v-for=\"warning in highWarnings\" :key=\"warning.id\" class=\"warning-item high unread\">\n                <div class=\"warning-icon\">\n                  <el-icon :size=\"24\"><CircleCloseFilled /></el-icon>\n                </div>\n                <div class=\"warning-content\">\n                  <div class=\"warning-header\">\n                    <el-tag type=\"danger\" size=\"small\">高风险</el-tag>\n                    <span class=\"warning-time\">{{ warning.time }}</span>\n                  </div>\n                  <h4>{{ warning.title }}</h4>\n                  <p>{{ warning.content }}</p>\n                  <el-alert :title=\"warning.action\" type=\"error\" :closable=\"false\" show-icon style=\"margin-top: 10px;\" />\n                </div>\n              </div>\n            </el-tab-pane>\n\n            <el-tab-pane label=\"健康提醒\" name=\"reminder\">\n              <div v-for=\"reminder in reminders\" :key=\"reminder.id\" class=\"reminder-item\">\n                <div class=\"reminder-icon\" :class=\"reminder.type\">\n                  <el-icon><Bell /></el-icon>\n                </div>\n                <div class=\"reminder-content\">\n                  <h4>{{ reminder.title }}</h4>\n                  <p>{{ reminder.content }}</p>\n                  <span class=\"reminder-time\">{{ reminder.time }}</span>\n                </div>\n              </div>\n            </el-tab-pane>\n          </el-tabs>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card>\n          <template #header>\n            <span>预警统计</span>\n          </template>\n          <el-descriptions :column=\"1\" border>\n            <el-descriptions-item label=\"今日预警\">\n              <el-badge :value=\"warningStats.today\" :type=\"warningStats.today > 0 ? 'danger' : 'info'\" />\n            </el-descriptions-item>\n            <el-descriptions-item label=\"本周预警\">{{ warningStats.week }}次</el-descriptions-item>\n            <el-descriptions-item label=\"未处理\">{{ warningStats.unread }}次</el-descriptions-item>\n            <el-descriptions-item label=\"已处理\">{{ warningStats.resolved }}次</el-descriptions-item>\n          </el-descriptions>\n        </el-card>\n\n        <el-card style=\"margin-top: 20px;\">\n          <template #header>\n            <span>预警阈值设置</span>\n          </template>\n          <el-form label-width=\"100px\">\n            <el-form-item label=\"血糖上限\">\n              <el-input-number v-model=\"thresholds.bloodSugarHigh\" :min=\"5\" :max=\"15\" :step=\"0.1\" />\n              <span style=\"margin-left: 5px;\">mmol/L</span>\n            </el-form-item>\n            <el-form-item label=\"血压上限\">\n              <el-input-number v-model=\"thresholds.bloodPressureHigh\" :min=\"100\" :max=\"200\" />\n              <span style=\"margin-left: 5px;\">mmHg</span>\n            </el-form-item>\n            <el-form-item label=\"心率上限\">\n              <el-input-number v-model=\"thresholds.heartRateHigh\" :min=\"60\" :max=\"150\" />\n              <span style=\"margin-left: 5px;\">bpm</span>\n            </el-form-item>\n            <el-form-item label=\"BMI上限\">\n              <el-input-number v-model=\"thresholds.bmiHigh\" :min=\"18\" :max=\"40\" :step=\"0.1\" />\n            </el-form-item>\n            <el-form-item>\n              <el-button type=\"primary\" @click=\"saveThresholds\">保存设置</el-button>\n            </el-form-item>\n          </el-form>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { Setting, Bell, CircleCloseFilled, WarningFilled, Warning, InfoFilled } from '@element-plus/icons-vue'\nimport { ElMessage } from 'element-plus'\n\nconst activeTab = ref('all')\n\nconst warnings = ref([\n  {\n    id: 1, level: '高风险', title: '血糖严重超标预警',\n    content: '您今日空腹血糖测量值为8.2mmol/L，已超过警戒线。建议立即调整饮食并咨询医生。',\n    action: '建议：1）立即就医；2）严格控制碳水摄入；3）增加运动量',\n    time: '2025-01-10 09:30', read: false\n  },\n  {\n    id: 2, level: '中风险', title: '血压波动预警',\n    content: '近3天血压测量值波动较大（120-158/80-95），建议规律作息并监测血压。',\n    time: '2025-01-10 08:15', read: false\n  },\n  {\n    id: 3, level: '低风险', title: '体重增加提醒',\n    content: '近一个月体重增加2kg，已接近超重上限，建议控制饮食。',\n    time: '2025-01-09 20:00', read: true\n  },\n  {\n    id: 4, level: '中风险', title: '血脂异常提醒',\n    content: '上次体检血脂指标偏高，已超过3个月未复查，建议近期安排复查。',\n    time: '2025-01-08 10:00', read: true\n  }\n])\n\nconst reminders = ref([\n  { id: 1, type: 'medication', title: '用药提醒', content: '二甲双胍 500mg - 晚餐后服用', time: '18:00' },\n  { id: 2, type: 'exercise', title: '运动提醒', content: '今日还未运动，建议进行30分钟散步', time: '19:00' },\n  { id: 3, type: 'checkup', title: '复查提醒', content: '心血管科复查还有15天', time: '全天' },\n  { id: 4, type: 'measurement', title: '测量提醒', content: '请测量今日睡前血压', time: '21:00' }\n])\n\nconst thresholds = ref({\n  bloodSugarHigh: 7.0,\n  bloodPressureHigh: 140,\n  heartRateHigh: 100,\n  bmiHigh: 24\n})\n\nconst warningStats = ref({\n  today: 2,\n  week: 8,\n  unread: 2,\n  resolved: 15\n})\n\nconst highWarnings = computed(() => warnings.value.filter(w => w.level === '高风险'))\n\nconst getLevelType = (level) => {\n  const map = { '高风险': 'danger', '中风险': 'warning', '低风险': 'info' }\n  return map[level] || 'info'\n}\n\nconst getWarningIcon = (level) => {\n  const map = { '高风险': 'CircleCloseFilled', '中风险': 'WarningFilled', '低风险': 'InfoFilled' }\n  return map[level] || 'InfoFilled'\n}\n\nconst markAllRead = () => {\n  warnings.value.forEach(w => w.read = true)\n  ElMessage.success('已全部标记为已读')\n}\n\nconst handleWarning = (warning) => {\n  warning.read = true\n  ElMessage.info(`处理预警: ${warning.title}`)\n}\n\nconst dismissWarning = (warning) => {\n  warning.read = true\n  ElMessage.success('已忽略')\n}\n\nconst showSettings = () => {\n  ElMessage.info('打开预警设置')\n}\n\nconst saveThresholds = () => {\n  ElMessage.success('预警阈值保存成功')\n}\n</script>\n\n<style scoped>\n.early-warning {\n  padding: 20px;\n}\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.warning-item {\n  display: flex;\n  gap: 15px;\n  padding: 15px;\n  margin-bottom: 10px;\n  border-radius: 8px;\n  background: #f5f7fa;\n}\n.warning-item.unread {\n  background: #ecf5ff;\n  border-left: 3px solid #409EFF;\n}\n.warning-item.high {\n  background: #fef0f0;\n  border-left: 3px solid #F56C6C;\n}\n.warning-icon {\n  flex-shrink: 0;\n}\n.warning-item.high .warning-icon { color: #F56C6C; }\n.warning-item.medium .warning-icon { color: #E6A23C; }\n.warning-item.low .warning-icon { color: #909399; }\n.warning-content {\n  flex: 1;\n}\n.warning-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 8px;\n}\n.warning-time {\n  color: #999;\n  font-size: 12px;\n}\n.warning-content h4 {\n  margin: 0 0 5px 0;\n}\n.warning-content p {\n  margin: 0;\n  color: #666;\n  font-size: 13px;\n}\n.warning-actions {\n  margin-top: 10px;\n}\n.reminder-item {\n  display: flex;\n  gap: 15px;\n  padding: 15px;\n  margin-bottom: 10px;\n  background: #f5f7fa;\n  border-radius: 8px;\n}\n.reminder-icon {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.reminder-icon.medication { background: #e6f7ff; color: #409EFF; }\n.reminder-icon.exercise { background: #f0f9eb; color: #67C23A; }\n.reminder-icon.checkup { background: #fdf6ec; color: #E6A23C; }\n.reminder-icon.measurement { background: #f4f4f5; color: #909399; }\n.reminder-content h4 {\n  margin: 0 0 5px 0;\n}\n.reminder-content p {\n  margin: 0 0 5px 0;\n  color: #666;\n}\n.reminder-time {\n  color: #999;\n  font-size: 12px;\n}\n</style>\n"],"mappings":"AAsHA,SAASA,GAAG,EAAEC,QAAQ,QAAQ,KAAI;AAClC,SAASC,OAAO,EAAEC,IAAI,EAAEC,iBAAiB,EAAEC,aAAa,EAAEC,OAAO,EAAEC,UAAU,QAAQ,yBAAwB;AAC7G,SAASC,SAAS,QAAQ,cAAa;;;;;;;IAEvC,MAAMC,SAAS,GAAGT,GAAG,CAAC,KAAK;IAE3B,MAAMU,QAAQ,GAAGV,GAAG,CAAC,CACnB;MACEW,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE,KAAK;MAAEC,KAAK,EAAE,UAAU;MACtCC,OAAO,EAAE,4CAA4C;MACrDC,MAAM,EAAE,8BAA8B;MACtCC,IAAI,EAAE,kBAAkB;MAAEC,IAAI,EAAE;IAClC,CAAC,EACD;MACEN,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE,KAAK;MAAEC,KAAK,EAAE,QAAQ;MACpCC,OAAO,EAAE,0CAA0C;MACnDE,IAAI,EAAE,kBAAkB;MAAEC,IAAI,EAAE;IAClC,CAAC,EACD;MACEN,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE,KAAK;MAAEC,KAAK,EAAE,QAAQ;MACpCC,OAAO,EAAE,6BAA6B;MACtCE,IAAI,EAAE,kBAAkB;MAAEC,IAAI,EAAE;IAClC,CAAC,EACD;MACEN,EAAE,EAAE,CAAC;MAAEC,KAAK,EAAE,KAAK;MAAEC,KAAK,EAAE,QAAQ;MACpCC,OAAO,EAAE,gCAAgC;MACzCE,IAAI,EAAE,kBAAkB;MAAEC,IAAI,EAAE;IAClC,EACD;IAED,MAAMC,SAAS,GAAGlB,GAAG,CAAC,CACpB;MAAEW,EAAE,EAAE,CAAC;MAAEQ,IAAI,EAAE,YAAY;MAAEN,KAAK,EAAE,MAAM;MAAEC,OAAO,EAAE,oBAAoB;MAAEE,IAAI,EAAE;IAAQ,CAAC,EAC1F;MAAEL,EAAE,EAAE,CAAC;MAAEQ,IAAI,EAAE,UAAU;MAAEN,KAAK,EAAE,MAAM;MAAEC,OAAO,EAAE,mBAAmB;MAAEE,IAAI,EAAE;IAAQ,CAAC,EACvF;MAAEL,EAAE,EAAE,CAAC;MAAEQ,IAAI,EAAE,SAAS;MAAEN,KAAK,EAAE,MAAM;MAAEC,OAAO,EAAE,aAAa;MAAEE,IAAI,EAAE;IAAK,CAAC,EAC7E;MAAEL,EAAE,EAAE,CAAC;MAAEQ,IAAI,EAAE,aAAa;MAAEN,KAAK,EAAE,MAAM;MAAEC,OAAO,EAAE,WAAW;MAAEE,IAAI,EAAE;IAAQ,EAClF;IAED,MAAMI,UAAU,GAAGpB,GAAG,CAAC;MACrBqB,cAAc,EAAE,GAAG;MACnBC,iBAAiB,EAAE,GAAG;MACtBC,aAAa,EAAE,GAAG;MAClBC,OAAO,EAAE;IACX,CAAC;IAED,MAAMC,YAAY,GAAGzB,GAAG,CAAC;MACvB0B,KAAK,EAAE,CAAC;MACRC,IAAI,EAAE,CAAC;MACPC,MAAM,EAAE,CAAC;MACTC,QAAQ,EAAE;IACZ,CAAC;IAED,MAAMC,YAAY,GAAG7B,QAAQ,CAAC,MAAMS,QAAQ,CAACqB,KAAK,CAACC,MAAM,CAACC,CAAC,IAAIA,CAAC,CAACrB,KAAK,KAAK,KAAK,CAAC;IAEjF,MAAMsB,YAAY,GAAItB,KAAK,IAAK;MAC9B,MAAMuB,GAAG,GAAG;QAAE,KAAK,EAAE,QAAQ;QAAE,KAAK,EAAE,SAAS;QAAE,KAAK,EAAE;MAAO;MAC/D,OAAOA,GAAG,CAACvB,KAAK,CAAC,IAAI,MAAK;IAC5B;IAEA,MAAMwB,cAAc,GAAIxB,KAAK,IAAK;MAChC,MAAMuB,GAAG,GAAG;QAAE,KAAK,EAAE,mBAAmB;QAAE,KAAK,EAAE,eAAe;QA