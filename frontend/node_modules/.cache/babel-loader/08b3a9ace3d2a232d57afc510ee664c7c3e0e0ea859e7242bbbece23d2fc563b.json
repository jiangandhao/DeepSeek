{"ast":null,"code":"import { ref } from 'vue';\nimport { MagicStick, UploadFilled, Document, Loading, CircleCheck } from '@element-plus/icons-vue';\nimport { ElMessage } from 'element-plus';\nexport default {\n  __name: 'ImageAnalysis',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const activeType = ref('lung');\n    const analyzing = ref(false);\n    const uploadedFile = ref(null);\n    const analysisResult = ref(null);\n    const handleFileChange = file => {\n      uploadedFile.value = file.raw;\n      analysisResult.value = null;\n    };\n    const getSeverityType = severity => {\n      const map = {\n        '高': 'danger',\n        '中': 'warning',\n        '低': 'info'\n      };\n      return map[severity] || 'info';\n    };\n    const analyzeImage = async () => {\n      analyzing.value = true;\n      analysisResult.value = null;\n      try {\n        await new Promise(resolve => setTimeout(resolve, 3000));\n        analysisResult.value = {\n          level: 'warning',\n          icon: 'Warning',\n          status: '发现异常，需进一步检查',\n          findings: [{\n            name: '肺结节',\n            severity: '中',\n            x: 35,\n            y: 40,\n            description: '右肺上叶见一磨玻璃结节，大小约6mm',\n            suggession: '建议3个月后复查CT，观察结节变化'\n          }, {\n            name: '肺纹理增多',\n            severity: '低',\n            x: 60,\n            y: 55,\n            description: '双肺纹理增多、增粗',\n            suggestion: '可能与吸烟或慢性炎症有关，建议戒烟'\n          }],\n          diagnosis: '1. 右肺上叶磨玻璃结节（GGN），建议随访观察；2. 双肺纹理增多，考虑慢性支气管炎可能。',\n          disclaimer: '⚠️ 本分析结果仅供参考，不能替代专业医生的诊断。请将结果带给主治医生进行综合判断。'\n        };\n\n        // 修正 findings 中的 suggestion 字段\n        analysisResult.value.findings[0].suggestion = '建议3个月后复查CT，观察结节变化';\n        ElMessage.success('分析完成');\n      } catch (error) {\n        ElMessage.error('分析失败');\n      } finally {\n        analyzing.value = false;\n      }\n    };\n    const __returned__ = {\n      activeType,\n      analyzing,\n      uploadedFile,\n      analysisResult,\n      handleFileChange,\n      getSeverityType,\n      analyzeImage,\n      ref,\n      get MagicStick() {\n        return MagicStick;\n      },\n      get UploadFilled() {\n        return UploadFilled;\n      },\n      get Document() {\n        return Document;\n      },\n      get Loading() {\n        return Loading;\n      },\n      get CircleCheck() {\n        return CircleCheck;\n      },\n      get ElMessage() {\n        return ElMessage;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","MagicStick","UploadFilled","Document","Loading","CircleCheck","ElMessage","activeType","analyzing","uploadedFile","analysisResult","handleFileChange","file","value","raw","getSeverityType","severity","map","analyzeImage","Promise","resolve","setTimeout","level","icon","status","findings","name","x","y","description","suggession","suggestion","diagnosis","disclaimer","success","error"],"sources":["C:/Users/wangj/Desktop/deepseek-health-management/frontend/src/views/checkup/ImageAnalysis.vue"],"sourcesContent":["<template>\n  <div class=\"image-analysis\">\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\">\n        <el-card>\n          <template #header>\n            <div class=\"card-header\">\n              <span>AI影像分析</span>\n              <el-button type=\"primary\" @click=\"analyzeImage\" :loading=\"analyzing\" :disabled=\"!uploadedFile\">\n                <el-icon><MagicStick /></el-icon>\n                开始分析\n              </el-button>\n            </div>\n          </template>\n\n          <el-upload\n            class=\"upload-area\"\n            drag\n            :auto-upload=\"false\"\n            :on-change=\"handleFileChange\"\n            :show-file-list=\"false\"\n            accept=\"image/*,.dcm\"\n          >\n            <div v-if=\"!uploadedFile\">\n              <el-icon :size=\"48\"><UploadFilled /></el-icon>\n              <div class=\"el-upload__text\">\n                拖拽文件到此处或 <em>点击上传</em>\n              </div>\n              <div class=\"el-upload__tip\">\n                支持 JPG、PNG、DICOM 格式的医学影像\n              </div>\n            </div>\n            <div v-else class=\"uploaded-preview\">\n              <el-icon :size=\"32\"><Document /></el-icon>\n              <span>{{ uploadedFile.name }}</span>\n            </div>\n          </el-upload>\n\n          <el-divider />\n\n          <el-tabs v-model=\"activeType\">\n            <el-tab-pane label=\"肺部CT\" name=\"lung\">\n              <div class=\"analysis-placeholder\">\n                <div ref=\"lungChart\" style=\"height: 400px; background: #000; border-radius: 8px;\">\n                  <div v-if=\"analyzing\" class=\"analyzing-overlay\">\n                    <el-icon class=\"is-loading\" :size=\"32\"><Loading /></el-icon>\n                    <p>AI正在分析影像...</p>\n                  </div>\n                  <div v-else-if=\"analysisResult\" class=\"result-overlay\">\n                    <div v-for=\"(finding, index) in analysisResult.findings\" :key=\"index\"\n                         class=\"finding-marker\"\n                         :style=\"{ left: finding.x + '%', top: finding.y + '%' }\">\n                      <el-tooltip :content=\"finding.description\" placement=\"top\">\n                        <div class=\"marker\" :class=\"finding.severity\"></div>\n                      </el-tooltip>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </el-tab-pane>\n            <el-tab-pane label=\"X光片\" name=\"xray\">\n              <div class=\"analysis-placeholder\">\n                <div style=\"height: 400px; background: #1a1a1a; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #666;\">\n                  请上传X光片进行分析\n                </div>\n              </div>\n            </el-tab-pane>\n            <el-tab-pane label=\"超声影像\" name=\"ultrasound\">\n              <div class=\"analysis-placeholder\">\n                <div style=\"height: 400px; background: #1a1a1a; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #666;\">\n                  请上传超声影像进行分析\n                </div>\n              </div>\n            </el-tab-pane>\n          </el-tabs>\n        </el-card>\n      </el-col>\n\n      <el-col :span=\"8\">\n        <el-card v-if=\"analysisResult\">\n          <template #header>\n            <span>分析结果</span>\n          </template>\n\n          <div class=\"result-summary\">\n            <div class=\"result-status\" :class=\"analysisResult.level\">\n              <el-icon :size=\"32\"><component :is=\"analysisResult.icon\" /></el-icon>\n              <h3>{{ analysisResult.status }}</h3>\n            </div>\n          </div>\n\n          <el-divider />\n\n          <h4>发现的问题</h4>\n          <div v-for=\"(finding, index) in analysisResult.findings\" :key=\"index\" class=\"finding-item\">\n            <div class=\"finding-header\">\n              <el-tag :type=\"getSeverityType(finding.severity)\" size=\"small\">{{ finding.severity }}</el-tag>\n              <span class=\"finding-name\">{{ finding.name }}</span>\n            </div>\n            <p class=\"finding-desc\">{{ finding.description }}</p>\n            <p class=\"finding-suggestion\">建议: {{ finding.suggestion }}</p>\n          </div>\n\n          <el-divider />\n\n          <h4>AI诊断意见</h4>\n          <p class=\"diagnosis\">{{ analysisResult.diagnosis }}</p>\n\n          <el-alert :title=\"analysisResult.disclaimer\" type=\"warning\" :closable=\"false\" show-icon style=\"margin-top: 15px;\" />\n        </el-card>\n\n        <el-card v-else>\n          <template #header>\n            <span>使用说明</span>\n          </template>\n          <div class=\"instructions\">\n            <div class=\"instruction-item\">\n              <el-icon><CircleCheck /></el-icon>\n              <div>\n                <h4>上传影像</h4>\n                <p>支持CT、X光、超声等医学影像</p>\n              </div>\n            </div>\n            <div class=\"instruction-item\">\n              <el-icon><MagicStick /></el-icon>\n              <div>\n                <h4>AI分析</h4>\n                <p>AI自动识别病变区域和异常指标</p>\n              </div>\n            </div>\n            <div class=\"instruction-item\">\n              <el-icon><Document /></el-icon>\n              <div>\n                <h4>生成报告</h4>\n                <p>自动生成分析报告和诊断建议</p>\n              </div>\n            </div>\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { MagicStick, UploadFilled, Document, Loading, CircleCheck } from '@element-plus/icons-vue'\nimport { ElMessage } from 'element-plus'\n\nconst activeType = ref('lung')\nconst analyzing = ref(false)\nconst uploadedFile = ref(null)\nconst analysisResult = ref(null)\n\nconst handleFileChange = (file) => {\n  uploadedFile.value = file.raw\n  analysisResult.value = null\n}\n\nconst getSeverityType = (severity) => {\n  const map = { '高': 'danger', '中': 'warning', '低': 'info' }\n  return map[severity] || 'info'\n}\n\nconst analyzeImage = async () => {\n  analyzing.value = true\n  analysisResult.value = null\n\n  try {\n    await new Promise(resolve => setTimeout(resolve, 3000))\n\n    analysisResult.value = {\n      level: 'warning',\n      icon: 'Warning',\n      status: '发现异常，需进一步检查',\n      findings: [\n        {\n          name: '肺结节',\n          severity: '中',\n          x: 35,\n          y: 40,\n          description: '右肺上叶见一磨玻璃结节，大小约6mm',\n          suggession: '建议3个月后复查CT，观察结节变化'\n        },\n        {\n          name: '肺纹理增多',\n          severity: '低',\n          x: 60,\n          y: 55,\n          description: '双肺纹理增多、增粗',\n          suggestion: '可能与吸烟或慢性炎症有关，建议戒烟'\n        }\n      ],\n      diagnosis: '1. 右肺上叶磨玻璃结节（GGN），建议随访观察；2. 双肺纹理增多，考虑慢性支气管炎可能。',\n      disclaimer: '⚠️ 本分析结果仅供参考，不能替代专业医生的诊断。请将结果带给主治医生进行综合判断。'\n    }\n\n    // 修正 findings 中的 suggestion 字段\n    analysisResult.value.findings[0].suggestion = '建议3个月后复查CT，观察结节变化'\n\n    ElMessage.success('分析完成')\n  } catch (error) {\n    ElMessage.error('分析失败')\n  } finally {\n    analyzing.value = false\n  }\n}\n</script>\n\n<style scoped>\n.image-analysis {\n  padding: 20px;\n}\n.card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.upload-area {\n  width: 100%;\n}\n.uploaded-preview {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 20px;\n}\n.analyzing-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  background: rgba(0, 0, 0, 0.7);\n  color: white;\n}\n.result-overlay {\n  position: relative;\n  width: 100%;\n  height: 100%;\n}\n.finding-marker {\n  position: absolute;\n  transform: translate(-50%, -50%);\n}\n.marker {\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  border: 2px solid;\n  cursor: pointer;\n  animation: pulse 1.5s infinite;\n}\n.marker.高 { border-color: #F56C6C; background: rgba(245, 108, 108, 0.3); }\n.marker.中 { border-color: #E6A23C; background: rgba(230, 162, 60, 0.3); }\n.marker.低 { border-color: #909399; background: rgba(144, 147, 153, 0.3); }\n@keyframes pulse {\n  0%, 100% { transform: scale(1); }\n  50% { transform: scale(1.2); }\n}\n.result-summary {\n  text-align: center;\n}\n.result-status {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 10px;\n  padding: 20px;\n  border-radius: 8px;\n}\n.result-status.warning { background: #fdf6ec; color: #E6A23C; }\n.result-status.success { background: #f0f9eb; color: #67C23A; }\n.result-status.danger { background: #fef0f0; color: #F56C6C; }\n.finding-item {\n  padding: 12px;\n  margin-bottom: 10px;\n  background: #f5f7fa;\n  border-radius: 8px;\n}\n.finding-header {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin-bottom: 8px;\n}\n.finding-name {\n  font-weight: bold;\n}\n.finding-desc {\n  margin: 5px 0;\n  color: #666;\n  font-size: 13px;\n}\n.finding-suggestion {\n  margin: 5px 0 0 0;\n  color: #409EFF;\n  font-size: 13px;\n}\n.diagnosis {\n  line-height: 1.8;\n  color: #333;\n}\n.instructions {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n.instruction-item {\n  display: flex;\n  gap: 12px;\n}\n.instruction-item .el-icon {\n  font-size: 24px;\n  color: #409EFF;\n}\n.instruction-item h4 {\n  margin: 0 0 5px 0;\n}\n.instruction-item p {\n  margin: 0;\n  color: #666;\n  font-size: 13px;\n}\n</style>\n"],"mappings":"AAiJA,SAASA,GAAG,QAAQ,KAAI;AACxB,SAASC,UAAU,EAAEC,YAAY,EAAEC,QAAQ,EAAEC,OAAO,EAAEC,WAAW,QAAQ,yBAAwB;AACjG,SAASC,SAAS,QAAQ,cAAa;;;;;;;IAEvC,MAAMC,UAAU,GAAGP,GAAG,CAAC,MAAM;IAC7B,MAAMQ,SAAS,GAAGR,GAAG,CAAC,KAAK;IAC3B,MAAMS,YAAY,GAAGT,GAAG,CAAC,IAAI;IAC7B,MAAMU,cAAc,GAAGV,GAAG,CAAC,IAAI;IAE/B,MAAMW,gBAAgB,GAAIC,IAAI,IAAK;MACjCH,YAAY,CAACI,KAAK,GAAGD,IAAI,CAACE,GAAE;MAC5BJ,cAAc,CAACG,KAAK,GAAG,IAAG;IAC5B;IAEA,MAAME,eAAe,GAAIC,QAAQ,IAAK;MACpC,MAAMC,GAAG,GAAG;QAAE,GAAG,EAAE,QAAQ;QAAE,GAAG,EAAE,SAAS;QAAE,GAAG,EAAE;MAAO;MACzD,OAAOA,GAAG,CAACD,QAAQ,CAAC,IAAI,MAAK;IAC/B;IAEA,MAAME,YAAY,GAAG,MAAAA,CAAA,KAAY;MAC/BV,SAAS,CAACK,KAAK,GAAG,IAAG;MACrBH,cAAc,CAACG,KAAK,GAAG,IAAG;MAE1B,IAAI;QACF,MAAM,IAAIM,OAAO,CAACC,OAAO,IAAIC,UAAU,CAACD,OAAO,EAAE,IAAI,CAAC;QAEtDV,cAAc,CAACG,KAAK,GAAG;UACrBS,KAAK,EAAE,SAAS;UAChBC,IAAI,EAAE,SAAS;UACfC,MAAM,EAAE,aAAa;UACrBC,QAAQ,EAAE,CACR;YACEC,IAAI,EAAE,KAAK;YACXV,QAAQ,EAAE,GAAG;YACbW,CAAC,EAAE,EAAE;YACLC,CAAC,EAAE,EAAE;YACLC,WAAW,EAAE,oBAAoB;YACjCC,UAAU,EAAE;UACd,CAAC,EACD;YACEJ,IAAI,EAAE,OAAO;YACbV,QAAQ,EAAE,GAAG;YACbW,CAAC,EAAE,EAAE;YACLC,CAAC,EAAE,EAAE;YACLC,WAAW,EAAE,WAAW;YACxBE,UAAU,EAAE;UACd,EACD;UACDC,SAAS,EAAE,gDAAgD;UAC3DC,UAAU,EAAE;QACd;;QAEA;QACAvB,cAAc,CAACG,KAAK,CAACY,QAAQ,CAAC,CAAC,CAAC,CAACM,UAAU,GAAG,mBAAkB;QAEhEzB,SAAS,CAAC4B,OAAO,CAAC,MAAM;MAC1B,CAAC,CAAC,OAAOC,KAAK,EAAE;QACd7B,SAAS,CAAC6B,KAAK,CAAC,MAAM;MACxB,CAAC,SAAS;QACR3B,SAAS,CAACK,KAAK,GAAG,KAAI;MACxB;IACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}